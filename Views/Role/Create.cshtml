@using BookStore.Dtos.Admin.Role
@model CreateRoleDto
@{
    ViewData["Title"] = "Thêm vai trò mới";
    ViewData["BreadcrumbParent"] = "Tài Khoản và Vai Trò";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Role");
}

<style>
    .form-card { background:#fff; border:1px solid #e8e8e8; border-radius:10px; overflow:hidden; max-width:760px; margin:0 auto; }
    .form-card-header { padding:16px 24px; border-bottom:1px solid #e8e8e8; }
    .form-card-header h5 { font-weight:600; font-size:1rem; color:#1a1a2e; margin:0; }
    .form-card-body { padding:24px; }
    .field-label { font-size:.8rem; font-weight:500; color:#595959; margin-bottom:5px; }
    .form-control, .form-select { font-size:.875rem; border-radius:6px; border-color:#d9d9d9; }
    .form-control:focus, .form-select:focus { border-color:#1677ff; box-shadow:0 0 0 .2rem rgba(22,119,255,.15); }
    .field-hint { font-size:.775rem; color:#8c8c8c; margin-top:4px; }
    .form-divider { border:none; border-top:1px solid #f0f0f0; margin:20px 0; }
    .btn-save { background-color:#1677ff; border-color:#1677ff; font-size:.875rem; padding:7px 20px; border-radius:6px; }
    .btn-save:hover { background-color:#0958d9; border-color:#0958d9; }
    .btn-cancel { font-size:.875rem; padding:7px 16px; border-radius:6px; }
</style>

<div class="book-management-header" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
    <h4 style="font-weight:600;font-size:1.25rem;color:#1a1a2e;margin:0">Thêm vai trò mới</h4>
</div>

<div class="form-card">
    <div class="form-card-header">
        <h5>Thông tin vai trò</h5>
    </div>
    <div class="form-card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="font-size:.875rem;border-radius:6px"></div>

            <div class="mb-3">
                <label class="field-label">Tên vai trò <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="Ví dụ: Accountant" />
                <span asp-validation-for="Name" class="text-danger" style="font-size:.775rem"></span>
                <div class="field-hint">Tên vai trò phải là duy nhất và không trùng với vai trò hiện có.</div>
            </div>

            <div class="mb-3">
                <label class="field-label">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Mô tả chức năng của vai trò này..."></textarea>
                <span asp-validation-for="Description" class="text-danger" style="font-size:.775rem"></span>
            </div>

            <hr class="form-divider" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-save">
                    <i class="bi bi-floppy me-1"></i> Lưu
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-cancel">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
