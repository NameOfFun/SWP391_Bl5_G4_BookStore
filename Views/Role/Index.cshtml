@using BookStore.Dtos.Admin.Role
@model IReadOnlyList<RoleListDto>
@{
    ViewData["Title"] = "Quản lý vai trò";
    ViewData["BreadcrumbParent"] = "Tài Khoản và Vai Trò";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "Role");
}

<style>
    .book-management-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
    .book-management-header h4 { font-weight:600; font-size:1.25rem; color:#1a1a2e; margin:0; }
    .book-table-card { background:#fff; border:1px solid #e8e8e8; border-radius:10px; overflow:hidden; }
    .book-table { margin:0; font-size:0.875rem; }
    .book-table thead tr th { background-color:#fafafa; color:#595959; font-weight:600; font-size:0.8125rem; padding:12px 14px; border-bottom:1px solid #e8e8e8; border-top:none; white-space:nowrap; }
    .book-table tbody tr td { padding:12px 14px; border-bottom:1px solid #f0f0f0; vertical-align:middle; color:#262626; }
    .book-table tbody tr:last-child td { border-bottom:none; }
    .book-table tbody tr:hover { background-color:#fafafa; }
    .badge-active { background-color:#f6ffed; color:#52c41a; border:1px solid #b7eb8f; font-weight:500; font-size:0.75rem; padding:3px 10px; border-radius:20px; }
    .badge-inactive { background-color:#fff2f0; color:#ff4d4f; border:1px solid #ffccc7; font-weight:500; font-size:0.75rem; padding:3px 10px; border-radius:20px; }
    .badge-system { background-color:#e6f4ff; color:#1677ff; border:1px solid #91caff; font-weight:500; font-size:0.75rem; padding:3px 10px; border-radius:20px; }
    .btn-action { width:32px; height:32px; padding:0; display:inline-flex; align-items:center; justify-content:center; border-radius:6px; font-size:0.875rem; border:1px solid; }
    .btn-edit { color:#fa8c16; border-color:#ffd591; background:#fff; }
    .btn-edit:hover { background:#fff7e6; color:#fa8c16; border-color:#fa8c16; }
    .btn-deactivate { color:#8c8c8c; border-color:#d9d9d9; background:#fff; }
    .btn-deactivate:hover { background:#f5f5f5; border-color:#8c8c8c; }
    .btn-activate { color:#52c41a; border-color:#b7eb8f; background:#fff; }
    .btn-activate:hover { background:#f6ffed; border-color:#52c41a; }
    .btn-add-new { background-color:#1677ff; border-color:#1677ff; font-size:0.875rem; padding:7px 18px; border-radius:6px; display:inline-flex; align-items:center; gap:6px; }
    .btn-add-new:hover { background-color:#0958d9; border-color:#0958d9; }
    .pagination-area { display:flex; justify-content:space-between; align-items:center; padding:14px 16px; border-top:1px solid #f0f0f0; font-size:0.875rem; color:#595959; }
    .pagination-controls { display:flex; gap:4px; align-items:center; }
    .page-btn { min-width:32px; height:32px; border:1px solid #d9d9d9; background:#fff; color:#262626; border-radius:6px; font-size:0.8125rem; cursor:pointer; display:inline-flex; align-items:center; justify-content:center; padding:0 6px; transition:all .15s; }
    .page-btn:hover:not(:disabled) { border-color:#1677ff; color:#1677ff; }
    .page-btn.active { background:#1677ff; border-color:#1677ff; color:#fff; }
    .page-btn:disabled { opacity:0.4; cursor:not-allowed; }
    .empty-state { text-align:center; padding:48px 20px; color:#8c8c8c; }
    .empty-state i { font-size:2.5rem; display:block; margin-bottom:10px; color:#d9d9d9; }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="book-management-header">
    <h4>Quản lý vai trò</h4>
    <a asp-action="Create" class="btn btn-primary btn-add-new">
        <i class="bi bi-plus-lg"></i> Thêm vai trò
    </a>
</div>

<div class="card border-0 shadow-sm mb-3" style="border-radius:10px">
    <div class="card-body py-3 px-4">
        <div class="row g-2 align-items-end">
            <div class="col">
                <label class="form-label mb-1" style="font-size:.8rem;font-weight:500;color:#595959">Tìm kiếm</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white border-end-0" style="border-radius:6px 0 0 6px">
                        <i class="bi bi-search text-muted" style="font-size:.85rem"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control border-start-0"
                           style="border-radius:0 6px 6px 0;font-size:.875rem"
                           placeholder="Tìm theo tên vai trò..." />
                </div>
            </div>
            <div class="col-md-auto">
                <label class="form-label mb-1" style="font-size:.8rem;font-weight:500;color:#595959">Trạng thái</label>
                <select id="statusFilter" class="form-select form-select-sm" style="border-radius:6px;font-size:.875rem;min-width:140px">
                    <option value="">Tất cả</option>
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
            <div class="col-md-auto">
                <button class="btn btn-primary btn-sm" onclick="applyFilter()" style="border-radius:6px;font-size:.875rem;padding:6px 16px">
                    <i class="bi bi-funnel me-1"></i>Lọc
                </button>
                <button class="btn btn-outline-secondary btn-sm ms-1" onclick="resetFilter()" style="border-radius:6px;font-size:.875rem;padding:6px 14px">
                    <i class="bi bi-x-lg me-1"></i>Xóa lọc
                </button>
            </div>
        </div>
    </div>
</div>

<div class="book-table-card">
    <table class="table book-table" id="roleTable">
        <thead>
            <tr>
                <th style="width:52px">STT</th>
                <th>Tên vai trò</th>
                <th>Mô tả</th>
                <th class="text-center" style="width:100px">Số người dùng</th>
                <th class="text-center" style="width:110px">Trạng thái</th>
                <th class="text-center" style="width:100px">Thao tác</th>
            </tr>
        </thead>
        <tbody id="roleTableBody">
            @{ int stt = 0; }
            @foreach (var role in Model)
            {
                stt++;
                <tr class="role-row" data-name="@role.Name.ToLower()" data-status="@(role.IsActive ? "active" : "inactive")">
                    <td class="row-stt">@stt</td>
                    <td><span class="fw-semibold">@role.Name</span></td>
                    <td><span class="text-muted">@(string.IsNullOrWhiteSpace(role.Description) ? "—" : role.Description)</span></td>
                    <td class="text-center">@role.UserCount</td>
                    <td class="text-center">
                        @if (role.IsActive)
                        {
                            <span class="badge-active">Active</span>
                        }
                        else
                        {
                            <span class="badge-inactive">Inactive</span>
                        }
                    </td>
                    <td class="text-center">
                        @if (role.Name != "Admin")
                        {
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="Edit" asp-route-id="@role.Id"
                                   class="btn-action btn-edit" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="ToggleActive" asp-route-id="@role.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('@(role.IsActive ? "Vô hiệu hóa vai trò này?" : "Kích hoạt vai trò này?")')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn-action @(role.IsActive ? "btn-activate" : "btn-deactivate")"
                                            title="@(role.IsActive ? "Vô hiệu hóa" : "Kích hoạt")">
                                        <i class="bi @(role.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <span class="text-muted" title="Vai trò Admin được bảo vệ">
                                <i class="bi bi-shield-lock"></i>
                            </span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div id="emptyState" class="empty-state" style="display:none">
        <i class="bi bi-shield"></i>
        Không tìm thấy vai trò nào
    </div>

    <div class="pagination-area">
        <span class="pagination-info" id="pageInfo">Hiển thị 0 bản ghi</span>
        <div class="pagination-controls" id="paginationControls"></div>
    </div>
</div>

<script>
    const PAGE_SIZE = 10;
    let currentPage = 1;
    let filteredRows = [];

    function applyFilter() {
        const search = document.getElementById('searchInput').value.toLowerCase().trim();
        const status = document.getElementById('statusFilter').value;
        const allRows = Array.from(document.querySelectorAll('.role-row'));

        filteredRows = allRows.filter(row => {
            const nameMatch = !search || row.dataset.name.includes(search);
            const statusMatch = !status || row.dataset.status === status;
            return nameMatch && statusMatch;
        });

        allRows.forEach(r => r.style.display = 'none');
        currentPage = 1;
        renderPage();
    }

    function renderPage() {
        const total = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        if (currentPage > totalPages) currentPage = totalPages;

        const start = (currentPage - 1) * PAGE_SIZE;
        const end = Math.min(start + PAGE_SIZE, total);

        filteredRows.forEach((r, i) => {
            r.style.display = (i >= start && i < end) ? '' : 'none';
            if (i >= start && i < end) r.querySelector('.row-stt').textContent = start + (i - start) + 1;
        });

        document.getElementById('emptyState').style.display = total === 0 ? '' : 'none';

        const info = document.getElementById('pageInfo');
        info.textContent = total === 0 ? 'Không có bản ghi nào' : `Hiển thị ${start + 1}–${end} của ${total} bản ghi`;

        renderPagination(totalPages);
    }

    function renderPagination(totalPages) {
        const container = document.getElementById('paginationControls');
        container.innerHTML = '';

        const prev = document.createElement('button');
        prev.className = 'page-btn';
        prev.textContent = 'Trước';
        prev.disabled = currentPage === 1;
        prev.onclick = () => { currentPage--; renderPage(); };
        container.appendChild(prev);

        const maxVisible = 5;
        let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
        let endPage = Math.min(totalPages, startPage + maxVisible - 1);
        if (endPage - startPage < maxVisible - 1) startPage = Math.max(1, endPage - maxVisible + 1);

        for (let i = startPage; i <= endPage; i++) {
            const btn = document.createElement('button');
            btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
            btn.textContent = i;
            const page = i;
            btn.onclick = () => { currentPage = page; renderPage(); };
            container.appendChild(btn);
        }

        const next = document.createElement('button');
        next.className = 'page-btn';
        next.textContent = 'Sau';
        next.disabled = currentPage === totalPages;
        next.onclick = () => { currentPage++; renderPage(); };
        container.appendChild(next);
    }

    function resetFilter() {
        document.getElementById('searchInput').value = '';
        document.getElementById('statusFilter').value = '';
        applyFilter();
    }

    document.getElementById('searchInput').addEventListener('keydown', e => { if (e.key === 'Enter') applyFilter(); });

    document.addEventListener('DOMContentLoaded', () => {
        filteredRows = Array.from(document.querySelectorAll('.role-row'));
        renderPage();
    });
</script>
