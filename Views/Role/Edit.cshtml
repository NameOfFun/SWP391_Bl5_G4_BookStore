@using BookStore.Dtos.Admin.Role
@model UpdateRoleDto
@{
    ViewData["Title"] = $"Chỉnh sửa vai trò: {Model.Name}";
}

<div class="container mt-4" style="max-width:600px">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Quản lý Vai trò</a></li>
            <li class="breadcrumb-item active">Chỉnh sửa</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-header text-white" style="background-color:#fa8c16">
            <h5 class="mb-0"><i class="bi bi-shield-gear me-2"></i>Chỉnh sửa vai trò</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Name" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Tên vai trò</label>
                        <p class="form-control-plaintext fw-semibold">@Model.Name</p>
                        <small class="text-muted">Tên vai trò không thể thay đổi.</small>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Mô tả chức năng của vai trò này..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" id="isActiveSwitch" />
                            <label class="form-check-label fw-semibold" for="isActiveSwitch">
                                Kích hoạt vai trò
                            </label>
                        </div>
                        <small class="text-muted">
                            Bỏ chọn để vô hiệu hóa vai trò — người dùng thuộc vai trò này sẽ không thể đăng nhập.
                        </small>
                    </div>
                </div>

                <hr class="my-4" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="bi bi-floppy me-1"></i> Cập nhật
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
