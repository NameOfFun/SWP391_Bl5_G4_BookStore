@model BookStore.Dtos.Common.CheckoutViewModel
@{
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}
<link href="~/css/bookshop.css" rel="stylesheet" asp-append-version="true" />

<section class="page-banner services-banner">
    <div class="container">
        <div class="banner-header">
            <h2>Thanh toán</h2>
            <span class="underline center"></span>
            <p class="lead">@Model.TotalQuantity sản phẩm</p>
        </div>
        <div class="breadcrumb">
            <ul>
                <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                <li>Thanh toán</li>
            </ul>
        </div>
    </div>
</section>

<div id="content" class="site-content">
    <div class="container" style="padding-bottom:48px">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-top:16px"></div>

        <form asp-action="Checkout" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="row" style="margin-top:16px">
                <div class="col-md-7">
                    <h4 style="margin-top:0">Thông tin giao hàng</h4>
                    <div class="form-group">
                        <label asp-for="Form.ShippingName">Họ và tên *</label>
                        <input asp-for="Form.ShippingName" class="form-control" />
                        <span asp-validation-for="Form.ShippingName" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Form.ShippingPhone">Số điện thoại *</label>
                        <input asp-for="Form.ShippingPhone" class="form-control" />
                        <span asp-validation-for="Form.ShippingPhone" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Form.ShippingAddress">Địa chỉ nhận hàng *</label>
                        <textarea asp-for="Form.ShippingAddress" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Form.ShippingAddress" class="text-danger"></span>
                    </div>
                    <h4 style="margin-top:24px">Phương thức thanh toán</h4>
                    <div class="form-group">
                        <input type="hidden" asp-for="Form.PaymentMethod" value="COD" />
                        <p style="margin:0;padding:10px 14px;background:#f9f9f9;border:1px solid #eee;border-radius:4px">
                            <i class="fa fa-money"></i>&nbsp;Thanh toán khi nhận hàng (COD)
                        </p>
                    </div>
                </div>

                <div class="col-md-5">
                    <div style="border:1px solid #eee;background:#fafafa;padding:18px;border-radius:6px">
                        <h4 style="margin-top:0">Đơn hàng của bạn</h4>
                        <table class="table" style="margin-bottom:12px">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-right">Tạm tính</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var l in Model.Lines)
                                {
                                    <tr>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:10px">
                                                <img src="@l.CoverUrl" alt="" style="width:40px;height:56px;object-fit:cover;border:1px solid #eee" />
                                                <div>
                                                    <div style="font-weight:600">@l.Title</div>
                                                    <div class="text-muted small">@l.UnitPrice.ToString("N0") đ × @l.Quantity</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-right" style="vertical-align:middle">@l.LineTotal.ToString("N0") đ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th>Tạm tính</th>
                                    <td class="text-right">@Model.Subtotal.ToString("N0") đ</td>
                                </tr>
                                <tr id="discountRow" style="@(Model.DiscountAmount > 0 ? "" : "display:none")">
                                    <th>Giảm giá (<span id="discountCodeLabel">@(Model.Form.VoucherCode ?? "")</span>)</th>
                                    <td class="text-right" id="discountDisplay" style="color:#5cb85c">
                                        -@Model.DiscountAmount.ToString("N0") đ
                                    </td>
                                </tr>
                                <tr>
                                    <th style="font-size:16px">Tổng cộng</th>
                                    <td class="text-right" id="grandTotalDisplay"
                                        style="color:#ff7236;font-size:20px;font-weight:700">@Model.GrandTotal.ToString("N0") đ</td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Voucher section -->
                        <div style="border-top:1px solid #eee;padding:12px 0 8px">
                            <div style="font-weight:600;margin-bottom:8px">
                                <i class="fa fa-tag"></i> Mã giảm giá
                            </div>

                            <!-- Input row (visible when no voucher applied) -->
                            <div id="voucherInputRow">
                                <div class="input-group" style="max-width:320px">
                                    <input type="text" id="voucherCodeInput" class="form-control"
                                           placeholder="Nhập mã giảm giá" maxlength="50"
                                           style="text-transform:uppercase" />
                                    <span class="input-group-btn">
                                        <button type="button" class="btn btn-default" id="applyVoucherBtn">
                                            Áp dụng
                                        </button>
                                    </span>
                                </div>
                            </div>

                            <!-- Applied state (hidden until apply succeeds) -->
                            <div id="voucherAppliedRow" style="display:none">
                                <span class="text-success">
                                    <i class="fa fa-check-circle"></i>
                                    <span id="voucherAppliedText"></span>
                                </span>
                                &nbsp;
                                <button type="button" class="btn btn-link btn-xs" id="removeVoucherBtn"
                                        style="color:#d9534f;padding:0">Xóa</button>
                            </div>

                            <!-- Error message -->
                            <div id="voucherError" class="text-danger" style="font-size:12px;margin-top:4px;display:none"></div>

                            <!-- Hidden input carried into form POST -->
                            <input type="hidden" name="Form.VoucherCode" id="voucherCodeHidden"
                                   value="@(Model.Form.VoucherCode ?? "")" />
                        </div>

                        <button type="submit" class="btn btn-primary btn-block btn-lg"
                                style="background:#ff7236;border-color:#ff7236;width:100%;padding:12px;font-weight:600">
                            Đặt hàng
                        </button>
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-default btn-block" style="width:100%;margin-top:8px">
                            Quay lại giỏ hàng
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        var subtotal = @Model.Subtotal;

        // Restore applied state on POST-failure roundtrip
        var initialCode = document.getElementById('voucherCodeHidden').value;
        if (initialCode) showApplied(initialCode, @Model.DiscountAmount);

        document.getElementById('applyVoucherBtn').onclick = function () {
            var code = document.getElementById('voucherCodeInput').value.trim().toUpperCase();
            if (!code) { showError('Vui lòng nhập mã giảm giá.'); return; }

            clearError();
            var btn = this;
            btn.disabled = true;
            btn.textContent = 'Đang kiểm tra…';

            $.ajax({
                url: '/Order/ApplyVoucher',
                type: 'POST',
                contentType: 'application/json',
                headers: { 'RequestVerificationToken': $('[name="__RequestVerificationToken"]').val() },
                data: JSON.stringify({ code: code }),
                success: function (data) {
                    if (data.ok) {
                        showApplied(code, data.discountAmount);
                    } else {
                        showError(data.message);
                    }
                },
                error: function () { showError('Không thể kết nối. Vui lòng thử lại.'); },
                complete: function () { btn.disabled = false; btn.textContent = 'Áp dụng'; }
            });
        };

        document.getElementById('removeVoucherBtn').onclick = function () {
            document.getElementById('voucherCodeHidden').value = '';
            document.getElementById('voucherInputRow').style.display = '';
            document.getElementById('voucherAppliedRow').style.display = 'none';
            document.getElementById('voucherCodeInput').value = '';
            document.getElementById('discountRow').style.display = 'none';
            document.getElementById('grandTotalDisplay').textContent = fmtVnd(subtotal);
            clearError();
        };

        function showApplied(code, discount) {
            document.getElementById('voucherCodeHidden').value = code;
            document.getElementById('voucherInputRow').style.display = 'none';
            document.getElementById('voucherAppliedRow').style.display = '';
            document.getElementById('voucherAppliedText').textContent =
                code + ' — giảm ' + fmtVnd(discount);
            document.getElementById('discountCodeLabel').textContent = code;
            document.getElementById('discountDisplay').textContent = '-' + fmtVnd(discount);
            document.getElementById('discountRow').style.display = '';
            document.getElementById('grandTotalDisplay').textContent =
                fmtVnd(Math.max(0, subtotal - discount));
            clearError();
        }

        function showError(msg) {
            var el = document.getElementById('voucherError');
            el.textContent = msg;
            el.style.display = '';
        }

        function clearError() {
            document.getElementById('voucherError').style.display = 'none';
        }

        function fmtVnd(n) {
            return n.toLocaleString('vi-VN') + ' đ';
        }
    })();
    </script>
}
