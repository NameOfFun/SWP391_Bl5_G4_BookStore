@model BookStore.Dtos.Common.OrderDetailDto
@using BookStore.Models
@using BookStore.Helpers
@{
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}
<link href="~/css/bookshop.css" rel="stylesheet" asp-append-version="true" />

@functions {
    string StatusLabel(OrderStatus s) => s switch
    {
        OrderStatus.Pending    => "Chờ xác nhận",
        OrderStatus.Confirmed  => "Đã xác nhận",
        OrderStatus.Processing => "Đang xử lý",
        OrderStatus.Delivered  => "Đã giao",
        OrderStatus.Cancelled  => "Đã hủy",
        _ => s.ToString()
    };

    string StatusHint(OrderStatus s) => s switch
    {
        OrderStatus.Pending    => "Đang chờ nhân viên xác nhận đơn",
        OrderStatus.Confirmed  => "Đơn đã xác nhận, đang chuẩn bị hàng",
        OrderStatus.Processing => "Đang đóng gói, sắp giao đến bạn",
        OrderStatus.Delivered  => "Đã giao thành công — thanh toán khi nhận",
        OrderStatus.Cancelled  => "Đơn đã bị hủy, kho được hoàn trả",
        _ => ""
    };

    string StatusColor(OrderStatus s) => s switch
    {
        OrderStatus.Pending    => "#faad14",
        OrderStatus.Confirmed  => "#1677ff",
        OrderStatus.Processing => "#722ed1",
        OrderStatus.Delivered  => "#52c41a",
        OrderStatus.Cancelled  => "#ff4d4f",
        _ => "#8c8c8c"
    };
}

<section class="page-banner services-banner">
    <div class="container">
        <div class="banner-header">
            <h2>Chi tiết đơn #@Model.OrderId</h2>
            <span class="underline center"></span>
            <p class="lead">Trạng thái: <strong>@StatusLabel(Model.Status)</strong></p>
        </div>
        <div class="breadcrumb">
            <ul>
                <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li><a asp-controller="Order" asp-action="MyOrders">Đơn hàng của tôi</a></li>
                <li>Đơn #@Model.OrderId</li>
            </ul>
        </div>
    </div>
</section>

<div id="content" class="site-content">
    <div class="container" style="padding-bottom:48px">
        <div style="margin-top:16px;padding:12px 16px;border-left:4px solid @StatusColor(Model.Status);background:#fafafa;border-radius:0 6px 6px 0;font-size:14px;color:#595959">
            <strong style="color:@StatusColor(Model.Status)">@StatusLabel(Model.Status)</strong>
            @if (!string.IsNullOrEmpty(StatusHint(Model.Status)))
            {
                <span style="margin-left:8px">— @StatusHint(Model.Status)</span>
            }
        </div>

        <div class="row" style="margin-top:16px">
            <div class="col-md-7">
                <h4>Giao hàng</h4>
                <table class="table">
                    <tr><th style="width:160px">Người nhận</th><td>@Model.ShippingName</td></tr>
                    <tr><th>Số điện thoại</th><td>@Model.ShippingPhone</td></tr>
                    <tr><th>Địa chỉ</th><td>@Model.ShippingAddress</td></tr>
                </table>
            </div>
            <div class="col-md-5">
                <h4>Tóm tắt</h4>
                <table class="table">
                    <tr><th>Ngày đặt</th><td>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    <tr><th>Thanh toán</th><td>@Model.PaymentMethod / @(OrderPaymentStatuses.IsPaid(Model.PaymentStatus) ? "Đã thanh toán" : OrderPaymentStatuses.IsAwaitingPayment(Model.PaymentStatus) ? "Chưa thanh toán" : Model.PaymentStatus ?? "—")</td></tr>
                    <tr><th>Tạm tính</th><td>@Model.SubTotal.ToString("N0") đ</td></tr>
                    @if (Model.DiscountAmount > 0)
                    {
                        <tr>
                            <th>Giảm giá@(Model.VoucherCode != null ? $" ({Model.VoucherCode})" : "")</th>
                            <td style="color:#5cb85c">-@Model.DiscountAmount.ToString("N0") đ</td>
                        </tr>
                    }
                    else
                    {
                        <tr><th>Giảm giá</th><td>0 đ</td></tr>
                    }
                    <tr><th>Tổng cộng</th><td style="color:#ff7236;font-weight:700">@Model.GrandTotal.ToString("N0") đ</td></tr>
                </table>
            </div>
        </div>

        <h4>Sản phẩm</h4>
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Sách</th>
                    <th class="text-right">Đơn giá</th>
                    <th class="text-center">Số lượng</th>
                    <th class="text-right">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var it in Model.Items)
                {
                    <tr>
                        <td>@it.Title</td>
                        <td class="text-right">@it.UnitPrice.ToString("N0") đ</td>
                        <td class="text-center">@it.Quantity</td>
                        <td class="text-right">@it.LineTotal.ToString("N0") đ</td>
                    </tr>
                }
            </tbody>
        </table>

        <a asp-action="MyOrders" class="btn btn-default">← Về danh sách đơn</a>
    </div>
</div>
