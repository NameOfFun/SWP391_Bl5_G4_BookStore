@model BookStore.Dtos.ShipperPerformanceViewModel
@{
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-gradient-success">
                <i class="fas fa-user-chart me-2"></i>Hiệu suất Cá nhân
            </h2>
            <p class="text-secondary">Xem lại thành quả làm việc và số tiền COD bạn đang quản lý.</p>
        </div>
    </div>

    <!-- ─── STAT CARDS ─── -->
    <div class="row">
        <!-- Tổng đơn hàng -->
        <div class="col-xl-3 col-sm-6 mb-4">
            <div class="card card-analytics border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-sm mb-0 text-uppercase font-weight-bold">Tổng đơn đã nhận</p>
                            <h4 class="font-weight-bolder mb-0">@Model.TotalOrders</h4>
                        </div>
                        <div class="icon icon-shape bg-gradient-info shadow-info text-center rounded-circle">
                            <i class="fas fa-box text-lg opacity-10" aria-hidden="true"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Thành công -->
        <div class="col-xl-3 col-sm-6 mb-4">
            <div class="card card-analytics border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-sm mb-0 text-uppercase font-weight-bold">Thành công</p>
                            <h4 class="font-weight-bolder text-success mb-0">@Model.SuccessfulOrders</h4>
                        </div>
                        <div class="icon icon-shape bg-gradient-success shadow-success text-center rounded-circle">
                            <i class="fas fa-check-circle text-lg opacity-10" aria-hidden="true"></i>
                        </div>
                    </div>
                    <p class="mb-0 mt-3">
                        Tỉ lệ: <span class="text-success text-sm font-weight-bolder">@Model.SuccessRate.ToString("0.##")%</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Tiền mặt COD -->
        <div class="col-xl-3 col-sm-6 mb-4">
            <div class="card card-analytics border-0 shadow-sm h-100 bg-dark text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-sm mb-0 text-uppercase text-light opacity-8">Tiền COD đang cầm</p>
                            <h4 class="font-weight-bolder mb-0 text-warning">@Model.TotalCodRevenue.ToString("N0") đ</h4>
                        </div>
                        <div class="icon icon-shape bg-gradient-warning shadow-warning text-center rounded-circle">
                            <i class="fas fa-money-bill-wave text-lg opacity-10" aria-hidden="true"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Thống kê tuần -->
        <div class="col-xl-3 col-sm-6 mb-4">
            <div class="card card-analytics border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-sm mb-0 text-uppercase font-weight-bold">Đơn trong tuần</p>
                            <h4 class="font-weight-bolder mb-0">@Model.OrdersThisWeek</h4>
                        </div>
                        <div class="icon icon-shape bg-gradient-primary shadow-primary text-center rounded-circle">
                            <i class="fas fa-calendar-week text-lg opacity-10" aria-hidden="true"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ─── CHARTS ─── -->
    <div class="row">
        <div class="col-lg-12 mb-4">
            <div class="card z-index-2 h-100 border-0 shadow-sm">
                <div class="card-header pb-0 pt-3 bg-transparent border-0">
                    <h6 class="text-capitalize">Biểu đồ Hiệu suất 7 ngày qua</h6>
                </div>
                <div class="card-body p-3">
                    <div class="chart">
                        <canvas id="myPerformanceChart" class="chart-canvas" height="350"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gradient-success {
        background: linear-gradient(310deg, #17ad37, #98ec2d);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .bg-gradient-info    { background: linear-gradient(310deg, #21d4fd, #2152ff); }
    .bg-gradient-primary { background: linear-gradient(310deg, #7928ca, #ff0080); }
    .bg-gradient-success { background: linear-gradient(310deg, #17ad37, #98ec2d); }
    .bg-gradient-warning { background: linear-gradient(310deg, #f53939, #fbcf33); }

    .card-analytics {
        transition: transform 0.3s ease;
        border-radius: 1rem;
    }
    .card-analytics:hover {
        transform: translateY(-5px);
    }

    .icon-shape {
        width: 48px;
        height: 48px;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        const perfCtx = document.getElementById('myPerformanceChart').getContext('2d');
        new Chart(perfCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.ChartData.Labels)),
                datasets: [
                    {
                        label: 'Thành công',
                        data: @Html.Raw(Json.Serialize(Model.ChartData.SuccessCounts)),
                        borderColor: '#17ad37',
                        backgroundColor: 'rgba(23, 173, 55, 0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4
                    },
                    {
                        label: 'Thất bại',
                        data: @Html.Raw(Json.Serialize(Model.ChartData.FailedCounts)),
                        borderColor: '#ea0606',
                        backgroundColor: 'rgba(234, 6, 6, 0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'top' }
                },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f8f9fa' } },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
}
