@model BookStore.Dtos.ShipperPerformanceViewModel
@{
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold text-gradient-primary">
                <i class="fas fa-chart-line me-2"></i>@(string.IsNullOrEmpty(Model.SelectedShipperId) ? "Tổng quan Hiệu suất Shipper" : $"Hiệu suất: {Model.SelectedShipperName}")
            </h2>
            <p class="text-secondary">Theo dõi chi tiết hiệu quả giao hàng và dòng tiền COD.</p>
        </div>
        <div class="col-md-4 text-end">
            <form asp-controller="Shipper" asp-action="ManagePerformance" method="get" class="d-flex gap-2">
                <select name="shipperId" class="form-select border-0 shadow-sm" onchange="this.form.submit()">
                    <option value="">-- Tất cả Shipper --</option>
                    @foreach (var s in Model.ShipperList)
                    {
                        <option value="@s.ShipperId" selected="@(Model.SelectedShipperId == s.ShipperId)">@s.ShipperName</option>
                    }
                </select>
                @if (!string.IsNullOrEmpty(Model.SelectedShipperId))
                {
                    <a asp-action="ManagePerformance" class="btn btn-outline-secondary shadow-sm"><i class="fas fa-undo"></i></a>
                }
            </form>
        </div>
    </div>

    <!-- ─── STAT CARDS ─── -->
    <div class="row">
        <!-- Tổng đơn hàng -->
        <div class="col-xl-3 col-sm-6 mb-4">
            <div class="card card-analytics border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-sm mb-0 text-uppercase font-weight-bold">Tổng đơn giao</p>
                            <h4 class="font-weight-bolder mb-0">@Model.TotalOrders</h4>
                        </div>
                        <div class="icon icon-shape bg-gradient-primary shadow-primary text-center rounded-circle">
                            <i class="fas fa-box text-lg opacity-10" aria-hidden="true"></i>
                        </div>
                    </div>
                    <p class="mb-0 mt-3">
                        <span class="text-success text-sm font-weight-bolder">@Model.OrdersToday</span> đơn hôm nay
                    </p>
                </div>
            </div>
        </div>

        <!-- Thành công -->
        <div class="col-xl-3 col-sm-6 mb-4">
            <div class="card card-analytics border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-sm mb-0 text-uppercase font-weight-bold">Thành công</p>
                            <h4 class="font-weight-bolder text-success mb-0">@Model.SuccessfulOrders</h4>
                        </div>
                        <div class="icon icon-shape bg-gradient-success shadow-success text-center rounded-circle">
                            <i class="fas fa-check-circle text-lg opacity-10" aria-hidden="true"></i>
                        </div>
                    </div>
                    <p class="mb-0 mt-3">
                        Tỉ lệ: <span class="text-success text-sm font-weight-bolder">@Model.SuccessRate.ToString("0.##")%</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Thất bại -->
        <div class="col-xl-3 col-sm-6 mb-4">
            <div class="card card-analytics border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-sm mb-0 text-uppercase font-weight-bold">Thất bại</p>
                            <h4 class="font-weight-bolder text-danger mb-0">@Model.FailedOrders</h4>
                        </div>
                        <div class="icon icon-shape bg-gradient-danger shadow-danger text-center rounded-circle">
                            <i class="fas fa-times-circle text-lg opacity-10" aria-hidden="true"></i>
                        </div>
                    </div>
                    <p class="mb-0 mt-3">
                        <span class="text-secondary text-sm">Cần chú ý cải thiện</span>
                    </p>
                </div>
            </div>
        </div>

        <!-- Tiền mặt COD -->
        <div class="col-xl-3 col-sm-6 mb-4">
            <div class="card card-analytics border-0 shadow-sm h-100 bg-dark text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-sm mb-0 text-uppercase text-light opacity-8">Tiền COD đang nắm giữ</p>
                            <h4 class="font-weight-bolder mb-0 text-warning">@Model.TotalCodRevenue.ToString("N0") đ</h4>
                        </div>
                        <div class="icon icon-shape bg-gradient-warning shadow-warning text-center rounded-circle">
                            <i class="fas fa-money-bill-wave text-lg opacity-10" aria-hidden="true"></i>
                        </div>
                    </div>
                    <p class="mb-0 mt-3 text-sm opacity-7">
                        Tổng tiền từ các đơn COD thành công
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- ─── CHARTS ─── -->
    <div class="row">
        <!-- Biểu đồ Hiệu suất -->
        <div class="col-lg-8 mb-4">
            <div class="card z-index-2 h-100 border-0 shadow-sm">
                <div class="card-header pb-0 pt-3 bg-transparent border-0">
                    <h6 class="text-capitalize">Biểu đồ Giao hàng (7 ngày qua)</h6>
                    <p class="text-sm mb-0">
                        <i class="fa fa-arrow-up text-success"></i>
                        <span class="font-weight-bold">Thống kê chi tiết</span> theo ngày
                    </p>
                </div>
                <div class="card-body p-3">
                    <div class="chart">
                        <canvas id="performanceChart" class="chart-canvas" height="300"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Biểu đồ Phân bổ -->
        <div class="col-lg-4 mb-4">
            <div class="card z-index-2 h-100 border-0 shadow-sm">
                <div class="card-header pb-0 pt-3 bg-transparent border-0">
                    <h6 class="text-capitalize">Tỉ lệ Hoàn thành</h6>
                </div>
                <div class="card-body p-3">
                    <div class="chart position-relative">
                        <canvas id="ratioChart" height="250"></canvas>
                        <div class="chart-overlay-text d-flex flex-column justify-content-center align-items-center">
                            <h3 class="font-weight-bold mb-0">@Model.SuccessRate.ToString("0")%</h3>
                            <span class="text-xs text-secondary">Thành công</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ─── SHIPPER TABLE ─── -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header pb-0 border-0 bg-transparent d-flex justify-content-between align-items-center">
                    <h6>Bảng Tổng Tất: Hiệu suất Shipper</h6>
                    <div class="dropdown">
                        <button class="btn btn-link text-secondary mb-0" id="dropdownMenuButton" data-bs-toggle="dropdown">
                            <i class="fa fa-ellipsis-v text-xs"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body px-0 pt-0 pb-2">
                    <div class="table-responsive p-0">
                        <table class="table align-items-center mb-0">
                            <thead>
                                <tr>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Shipper</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Tổng đơn nhận</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Thành công</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Thất bại</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Tỉ lệ</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Tiền COD</th>
                                    <th class="text-secondary opacity-7"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ShipperList)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex px-3 py-1">
                                                <div>
                                                    <div class="avatar-sm rounded-circle bg-light d-flex align-items-center justify-content-center me-3" style="width: 36px; height: 36px;">
                                                        <i class="fas fa-user text-primary"></i>
                                                    </div>
                                                </div>
                                                <div class="d-flex flex-column justify-content-center">
                                                    <h6 class="mb-0 text-sm">@item.ShipperName</h6>
                                                    <p class="text-xs text-secondary mb-0">ID: @item.ShipperId.Substring(0, 8)...</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="align-middle text-center text-sm">
                                            <span class="badge badge-sm bg-gradient-secondary">@item.TotalAssigned</span>
                                        </td>
                                        <td class="align-middle text-center text-sm">
                                            <span class="text-success font-weight-bold">@item.TotalDelivered</span>
                                        </td>
                                        <td class="align-middle text-center text-sm">
                                            <span class="text-danger font-weight-bold">@item.TotalFailed</span>
                                        </td>
                                        <td class="align-middle text-center">
                                            <div class="d-flex align-items-center justify-content-center">
                                                <span class="me-2 text-xs font-weight-bold">@item.SuccessRate.ToString("0")%</span>
                                                <div>
                                                    <div class="progress" style="width: 80px; height: 6px;">
                                                        <div class="progress-bar bg-gradient-success" role="progressbar" 
                                                             style="width: @item.SuccessRate.ToString("0")%;"></div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="align-middle text-center text-sm">
                                            <span class="text-dark font-weight-bold">@item.CodCollected.ToString("N0") đ</span>
                                        </td>
                                        <td class="align-middle">
                                            <a asp-action="ManagePerformance" asp-route-shipperId="@item.ShipperId" 
                                               class="text-secondary font-weight-bold text-xs">
                                                Chi tiết
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ─── RECENT ORDERS (DETAIL) ─── -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header pb-0 border-0 bg-transparent">
                    <h6>
                        <i class="fas fa-list-ul me-2"></i>
                        @(string.IsNullOrEmpty(Model.SelectedShipperId) ? "Các đơn hàng mới nhất (Toàn cửa hàng)" : $"Chi tiết đơn hàng của {Model.SelectedShipperName}")
                    </h6>
                </div>
                <div class="card-body px-0 pt-0 pb-2">
                    <div class="table-responsive p-0">
                        <table class="table align-items-center mb-0">
                            <thead>
                                <tr>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Mã đơn</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 ps-2">Khách hàng</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Ngày giao</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Tổng tiền</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td>
                                            <p class="text-xs font-weight-bold mb-0 ps-3">#@order.OrderId</p>
                                        </td>
                                        <td>
                                            <p class="text-xs font-weight-bold mb-0">@order.RecipientName</p>
                                        </td>
                                        <td class="align-middle text-center">
                                            <span class="text-secondary text-xs font-weight-bold">
                                                @(order.DeliveryDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                                            </span>
                                        </td>
                                        <td class="align-middle text-center">
                                            <span class="text-secondary text-xs font-weight-bold">@order.GrandTotal.ToString("N0") đ</span>
                                        </td>
                                        <td class="align-middle text-center text-sm">
                                            @{
                                                var badgeClass = order.Status switch
                                                {
                                                    BookStore.Models.OrderStatus.Delivered      => "bg-gradient-success",
                                                    BookStore.Models.OrderStatus.DeliveryFailed => "bg-gradient-danger",
                                                    BookStore.Models.OrderStatus.Delivering     => "bg-gradient-info",
                                                    _ => "bg-gradient-secondary"
                                                };
                                                var statusText = order.Status switch
                                                {
                                                    BookStore.Models.OrderStatus.Delivered      => "Thành công",
                                                    BookStore.Models.OrderStatus.DeliveryFailed => "Thất bại",
                                                    BookStore.Models.OrderStatus.Delivering     => "Đang giao",
                                                    BookStore.Models.OrderStatus.Shipped        => "Chờ nhận",
                                                    _ => order.Status.ToString()
                                                };
                                            }
                                            <span class="badge badge-sm @badgeClass">@statusText</span>
                                        </td>
                                    </tr>
                                }
                                @if (!Model.RecentOrders.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4">
                                            <p class="text-secondary text-xs mb-0">Không có đơn hàng nào được tìm thấy.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gradient-primary {
        background: linear-gradient(310deg, #7928ca, #ff0080);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .bg-gradient-primary { background: linear-gradient(310deg, #7928ca, #ff0080); }
    .bg-gradient-success { background: linear-gradient(310deg, #17ad37, #98ec2d); }
    .bg-gradient-danger  { background: linear-gradient(310deg, #ea0606, #ff667c); }
    .bg-gradient-warning { background: linear-gradient(310deg, #f53939, #fbcf33); }
    .bg-gradient-secondary { background: linear-gradient(310deg, #627594, #a8b8d8); }

    .card-analytics {
        transition: transform 0.3s ease;
        border-radius: 1rem;
    }
    .card-analytics:hover {
        transform: translateY(-5px);
    }

    .icon-shape {
        width: 48px;
        height: 48px;
        background-position: center;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chart-overlay-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -10%);
    }

    .progress-bar {
        border-radius: 4px;
    }

    .table thead th {
        padding: 0.75rem 1.5rem;
        border-bottom: 1px solid #e9ecef;
    }
    .table tbody td {
        padding: 0.75rem 1.5rem;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        // ─── PERFORMANCE CHART (LINE/BAR) ───
        const perfCtx = document.getElementById('performanceChart').getContext('2d');
        new Chart(perfCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.ChartData.Labels)),
                datasets: [
                    {
                        label: 'Thành công',
                        data: @Html.Raw(Json.Serialize(Model.ChartData.SuccessCounts)),
                        backgroundColor: '#17ad37',
                        borderRadius: 5,
                        barThickness: 15,
                    },
                    {
                        label: 'Thất bại',
                        data: @Html.Raw(Json.Serialize(Model.ChartData.FailedCounts)),
                        backgroundColor: '#ea0606',
                        borderRadius: 5,
                        barThickness: 15,
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top',
                        labels: { boxWidth: 10, usePointStyle: true }
                    }
                },
                scales: {
                    y: { beginAtZero: true, grid: { drawBorder: false, color: '#f8f9fa' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // ─── RATIO CHART (DOUGHNUT) ───
        const ratioCtx = document.getElementById('ratioChart').getContext('2d');
        new Chart(ratioCtx, {
            type: 'doughnut',
            data: {
                labels: ['Thành công', 'Thất bại'],
                datasets: [{
                    data: [@Model.SuccessfulOrders, @Model.FailedOrders],
                    backgroundColor: ['#17ad37', '#ea0606'],
                    borderWidth: 0,
                    cutout: '80%'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                }
            }
        });
    </script>
}
