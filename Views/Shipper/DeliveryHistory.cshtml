@model BookStore.Dtos.DeliveryHistoryViewModel
@using BookStore.Models
@{
    ViewData["Title"] = "Lịch sử giao hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --dh-blue: #1677ff;
        --dh-green: #52c41a;
        --dh-red: #ff4d4f;
        --dh-radius: 14px;
        --dh-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .dh-header {
        margin-bottom: 24px;
    }
    .dh-title {
        font-size: 1.5rem; font-weight: 800; color: #1a1a2e; margin: 0;
        display: flex; align-items: center; gap: 10px;
    }
    .dh-title i { color: var(--dh-blue); }

    /* ── Filters ── */
    .dh-filters {
        display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;
    }
    .dh-filter-btn {
        padding: 8px 18px; border-radius: 20px; font-size: 0.85rem; font-weight: 600;
        text-decoration: none; transition: all 0.2s; border: 1px solid #e8e8e8;
        background: #fff; color: #595959; display: flex; align-items: center; gap: 8px;
    }
    .dh-filter-btn:hover { background: #f5f5f5; border-color: #d9d9d9; color: #1a1a2e; }
    .dh-filter-btn.active {
        background: var(--dh-blue); color: #fff; border-color: var(--dh-blue);
        box-shadow: 0 4px 10px rgba(22, 119, 255, 0.25);
    }
    .dh-filter-btn .badge {
        font-size: 0.7rem; padding: 3px 6px; border-radius: 6px;
        background: rgba(0,0,0,0.1); color: inherit;
    }

    /* ── Table/Grid ── */
    .dh-card {
        background: #fff; border-radius: var(--dh-radius);
        box-shadow: var(--dh-shadow); overflow: hidden; border: 1px solid #f0f0f0;
    }
    .dh-table-wrap { overflow-x: auto; }
    .dh-table { width: 100%; border-collapse: collapse; }
    .dh-table th {
        background: #fafafa; padding: 14px 20px;
        font-size: 0.75rem; font-weight: 700; color: #8c8c8c;
        text-transform: uppercase; border-bottom: 1px solid #f0f0f0;
    }
    .dh-table td { padding: 16px 20px; border-bottom: 1px solid #f5f5f5; vertical-align: middle; }
    .dh-table tr:hover { background: #fafafa; }

    .dh-order-id { font-weight: 700; color: var(--dh-blue); }
    .dh-recipient { font-weight: 600; color: #1a1a2e; }
    .dh-date { font-size: 0.85rem; color: #8c8c8c; }
    .dh-amount { font-weight: 700; color: #1a1a2e; }

    /* ── Badges ── */
    .dh-badge {
        font-size: 0.75rem; font-weight: 700; padding: 5px 12px; border-radius: 20px;
        display: inline-flex; align-items: center; gap: 5px;
    }
    .dh-badge.success { background: #f6ffed; color: #389e0d; border: 1px solid #b7eb8f; }
    .dh-badge.failed  { background: #fff1f0; color: #cf1322; border: 1px solid #ffa39e; }
    
    /* Actions */
    .dh-btn-view {
        width: 36px; height: 36px; border-radius: 10px;
        display: inline-flex; align-items: center; justify-content: center;
        background: #f0f7ff; color: var(--dh-blue); text-decoration: none;
        transition: background .2s, color .2s;
        border: none;
    }
    .dh-btn-view:hover { background: var(--dh-blue); color: #fff; }

    .dh-btn-pod {
        width: 36px; height: 36px; border-radius: 10px;
        display: inline-flex; align-items: center; justify-content: center;
        background: #f6ffed; color: #52c41a; cursor: pointer;
        transition: all .2s; border: none; margin-right: 5px;
    }
    .dh-btn-pod:hover { background: #52c41a; color: #fff; }
    
    .pod-modal-img { width: 100%; border-radius: 12px; }

    .dh-empty { padding: 80px 40px; text-align: center; color: #bfbfbf; }
    .dh-empty i { font-size: 3.5rem; display: block; margin-bottom: 15px; }
</style>

<div class="dh-header">
    <h1 class="dh-title"><i class="bi bi-clock-history"></i> Lịch sử giao hàng</h1>
    <p class="text-muted mt-1 mb-0" style="font-size: 0.9rem">Danh sách các đơn hàng bạn đã xử lý thành công hoặc thất bại.</p>
</div>

<!-- Filters -->
<div class="dh-filters">
    <a href="@Url.Action("DeliveryHistory", "Shipper", new { filter = "all" })" 
       class="dh-filter-btn @(Model.ActiveFilter == "all" ? "active" : "")">
        Tất cả <span class="badge">@Model.TotalAll</span>
    </a>
    <a href="@Url.Action("DeliveryHistory", "Shipper", new { filter = "success" })" 
       class="dh-filter-btn @(Model.ActiveFilter == "success" ? "active" : "")">
        <i class="bi bi-check-circle"></i> Thành công <span class="badge">@Model.TotalSuccess</span>
    </a>
    <a href="@Url.Action("DeliveryHistory", "Shipper", new { filter = "failed" })" 
       class="dh-filter-btn @(Model.ActiveFilter == "failed" ? "active" : "")">
        <i class="bi bi-x-circle"></i> Thất bại <span class="badge">@Model.TotalFailed</span>
    </a>
</div>

<div class="dh-card">
    @if (Model.Orders == null || Model.Orders.Count == 0)
    {
        <div class="dh-empty">
            <i class="bi bi-mailbox"></i>
            <p>Không tìm thấy lịch sử giao hàng nào phù hợp.</p>
        </div>
    }
    else
    {
        <div class="dh-table-wrap">
            <table class="dh-table">
                <thead>
                    <tr>
                        <th style="width: 120px">Đơn hàng</th>
                        <th>Khách hàng</th>
                        <th>Ngày giao</th>
                        <th>Trạng thái</th>
                        <th style="text-align: right">Tổng tiền</th>
                        <th style="text-align: center; width: 100px">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        <tr>
                            <td><span class="dh-order-id">#@order.OrderId</span></td>
                            <td><div class="dh-recipient">@order.RecipientName</div></td>
                            <td>
                                <div class="dh-date">
                                    <i class="bi bi-calendar-check me-1"></i>
                                    @(order.DeliveryDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                                </div>
                            </td>
                            <td>
                                @if (order.Status == OrderStatus.Delivered)
                                {
                                    <span class="dh-badge success"><i class="bi bi-check-lg"></i> Thành công</span>
                                }
                                else
                                {
                                    <span class="dh-badge failed"><i class="bi bi-x"></i> Thất bại</span>
                                }
                            </td>
                            <td style="text-align: right">
                                <span class="dh-amount">@order.GrandTotal.ToString("N0")₫</span>
                            </td>
                             <td style="text-align: center; white-space: nowrap">
                                @if (!string.IsNullOrEmpty(order.ProofOfDeliveryImage))
                                {
                                    <button type="button" class="dh-btn-pod" title="Xem minh chứng"
                                            onclick="showPodModal('@order.ProofOfDeliveryImage', '@order.OrderId')">
                                        <i class="bi bi-camera"></i>
                                    </button>
                                }
                                <a asp-controller="Shipper" asp-action="DeliveryDetail" asp-route-id="@order.OrderId" 
                                   class="dh-btn-view" title="Xem chi tiết đơn #@order.OrderId">
                                    <i class="bi bi-arrow-right-short" style="font-size: 1.4rem"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
<!-- Modal Xem Minh Chứng -->
<div class="modal fade" id="podModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="podModalTitle">Minh chứng đơn hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <img id="podModalImg" src="" class="pod-modal-img" alt="POD" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function showPodModal(imgUrl, orderId) {
        document.getElementById('podModalImg').src = imgUrl;
        document.getElementById('podModalTitle').innerText = 'Minh chứng đơn hàng #' + orderId;
        new bootstrap.Modal(document.getElementById('podModal')).show();
    }
</script>
}
