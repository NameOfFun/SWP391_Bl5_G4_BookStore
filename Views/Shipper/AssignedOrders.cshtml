@model BookStore.Dtos.AssignedOrdersViewModel
@using BookStore.Models

@{
    ViewData["Title"] = "Đơn được giao";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var f = Model.ActiveFilter;
}

<style>
    :root {
        --ao-blue:   #1677ff;
        --ao-orange: #fa8c16;
        --ao-green:  #52c41a;
        --ao-red:    #ff4d4f;
        --ao-radius: 14px;
        --ao-shadow: 0 2px 12px rgba(0,0,0,.07);
    }

    /* ── Page header ── */
    .ao-page-header {
        display: flex; align-items: center;
        justify-content: space-between;
        margin-bottom: 24px; flex-wrap: wrap; gap: 12px;
    }
    .ao-page-title {
        font-size: 1.4rem; font-weight: 700;
        color: #1a1a2e; margin: 0;
        display: flex; align-items: center; gap: 10px;
    }
    .ao-page-title i { color: var(--ao-blue); }
    .ao-page-sub { color: #8c8c8c; font-size: .875rem; margin-top: 3px; }

    /* ── Filter Tabs ── */
    .ao-filter-bar {
        display: flex; gap: 8px;
        background: #fff; border-radius: 12px;
        padding: 6px; box-shadow: var(--ao-shadow);
        margin-bottom: 22px; flex-wrap: wrap;
    }
    .ao-filter-btn {
        display: flex; align-items: center; gap: 7px;
        padding: 9px 18px; border-radius: 9px;
        font-size: .875rem; font-weight: 500;
        color: #595959; text-decoration: none;
        border: none; background: transparent;
        cursor: pointer; transition: background .15s, color .15s;
        white-space: nowrap;
    }
    .ao-filter-btn:hover { background: #f0f7ff; color: var(--ao-blue); }
    .ao-filter-btn.active { background: #e6f4ff; color: var(--ao-blue); font-weight: 700; }
    .ao-filter-badge {
        font-size: .72rem; font-weight: 700;
        padding: 2px 8px; border-radius: 20px;
        background: rgba(22,119,255,.12); color: var(--ao-blue);
        min-width: 22px; text-align: center;
    }
    .ao-filter-btn.active .ao-filter-badge { background: var(--ao-blue); color: #fff; }

    /* ── Toast notifications ── */
    .ao-toast-wrap {
        margin-bottom: 16px;
    }
    .ao-alert {
        display: flex; align-items: center; gap: 10px;
        padding: 12px 18px; border-radius: 10px;
        font-size: .875rem; font-weight: 500;
        animation: slideIn .3s ease;
    }
    .ao-alert.success { background: #f6ffed; border: 1px solid #b7eb8f; color: #389e0d; }
    .ao-alert.error   { background: #fff1f0; border: 1px solid #ffa39e; color: #cf1322; }
    @@keyframes slideIn { from { opacity:0; transform:translateY(-8px);} to {opacity:1; transform:none;} }

    /* ── Table card ── */
    .ao-table-card {
        background: #fff; border-radius: var(--ao-radius);
        box-shadow: var(--ao-shadow); overflow: hidden;
    }
    .ao-table-toolbar {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; border-bottom: 1px solid #f0f0f0; flex-wrap: wrap; gap: 10px;
    }
    .ao-table-count {
        font-size: .85rem; color: #8c8c8c; font-weight: 500;
    }
    .ao-table-count strong { color: #1a1a2e; }

    /* Search input */
    .ao-search {
        display: flex; align-items: center; gap: 8px;
        background: #f5f5f5; border-radius: 8px;
        padding: 7px 14px; min-width: 220px;
    }
    .ao-search i { color: #bfbfbf; }
    .ao-search input {
        border: none; background: transparent;
        outline: none; font-size: .875rem; color: #262626;
        width: 100%;
    }

    /* ── Table ── */
    .ao-table { width: 100%; border-collapse: collapse; }
    .ao-table thead th {
        background: #fafafa; padding: 12px 16px;
        font-size: .78rem; font-weight: 600; color: #8c8c8c;
        text-transform: uppercase; letter-spacing: .5px;
        border-bottom: 1px solid #f0f0f0; white-space: nowrap;
    }
    .ao-table tbody tr {
        border-bottom: 1px solid #f5f5f5;
        transition: background .12s;
    }
    .ao-table tbody tr:last-child { border-bottom: none; }
    .ao-table tbody tr:hover { background: #fafeff; }
    .ao-table td {
        padding: 14px 16px; vertical-align: middle;
        font-size: .875rem; color: #262626;
    }

    /* Order ID cell */
    .ao-id { font-weight: 700; color: var(--ao-blue); font-size: .95rem; }
    .ao-id small { display: block; color: #bfbfbf; font-size: .72rem; font-weight: 400; }

    /* Customer cell */
    .ao-customer-name { font-weight: 600; color: #1a1a2e; }
    .ao-customer-phone { color: #8c8c8c; font-size: .8rem; display: flex; align-items:center; gap:4px; margin-top:2px; }

    /* Address */
    .ao-address {
        max-width: 200px; white-space: nowrap;
        overflow: hidden; text-overflow: ellipsis;
        color: #595959;
    }
    .ao-address:hover { white-space: normal; }

    /* Total */
    .ao-total { font-weight: 700; color: #1a1a2e; }

    /* Payment badge */
    .ao-pay {
        display: inline-flex; align-items: center; gap: 5px;
        font-size: .78rem; font-weight: 600; padding: 4px 10px;
        border-radius: 20px; white-space: nowrap;
    }
    .ao-pay.cod  { background: #fff7e6; color: #d46b08; }
    .ao-pay.paid { background: #f6ffed; color: #389e0d; }

    /* Status badge */
    .ao-status {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: .8rem; font-weight: 600; padding: 5px 12px;
        border-radius: 20px; white-space: nowrap;
    }
    .ao-status.assigned   { background: #e6f4ff; color: #1677ff; }
    .ao-status.delivering { background: #fff7e6; color: #fa8c16; }
    .ao-status i { font-size: .7rem; }

    /* Urgency dot */
    .ao-urgency {
        width: 8px; height: 8px; border-radius: 50%;
        display: inline-block; flex-shrink: 0;
    }
    .ao-urgency.critical { background: #ff4d4f; animation: blink 1s infinite; }
    .ao-urgency.high     { background: #fa8c16; }
    .ao-urgency.normal   { background: #52c41a; }
    @@keyframes blink { 0%,100%{opacity:1;} 50%{opacity:.3;} }

    /* Actions */
    .ao-actions { display: flex; gap: 8px; flex-wrap: nowrap; }
    .ao-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 7px 14px; border-radius: 8px;
        font-size: .8rem; font-weight: 600; cursor: pointer;
        border: none; transition: opacity .15s, transform .12s;
        text-decoration: none; white-space: nowrap;
    }
    .ao-btn:hover { opacity: .85; transform: scale(1.03); }
    .ao-btn.view    { 
        width: 36px; height: 36px; border-radius: 10px;
        background: #f0f7ff; color: var(--ao-blue); 
        padding: 0; justify-content: center;
    }
    .ao-btn.accept  { background: linear-gradient(135deg,#52c41a,#73d13d); color:#fff; }
    .ao-btn.reject  { background: #fff1f0; color: var(--ao-red); border: 1px solid #ffa39e; }
    .ao-btn.disabled-btn { background: #f5f5f5; color: #bfbfbf; cursor: not-allowed; pointer-events:none; }

    /* Empty state */
    .ao-empty {
        text-align: center; padding: 64px 24px; color: #bfbfbf;
    }
    .ao-empty i { font-size: 3.5rem; display: block; margin-bottom: 12px; }
    .ao-empty p { margin: 0; font-size: .95rem; }

    /* Modal */
    .ao-modal-reject .modal-header { border-bottom: 1px solid #f0f0f0; }
    .ao-modal-reject .modal-footer { border-top: 1px solid #f0f0f0; }

    /* Responsive */
    @@media (max-width: 900px) {
        .ao-table thead { display: none; }
        .ao-table tbody tr { display: block; margin: 12px; border: 1px solid #f0f0f0; border-radius: 10px; }
        .ao-table td {
            display: flex; justify-content: space-between;
            align-items: center; border-bottom: 1px solid #f8f8f8;
            padding: 10px 14px;
        }
        .ao-table td::before {
            content: attr(data-label);
            font-weight: 600; color: #8c8c8c;
            font-size: .78rem; flex-shrink: 0; margin-right: 12px;
        }
        .ao-address { max-width: none; }
    }
</style>

<!-- ── Page Header ── -->
<div class="ao-page-header">
    <div>
        <h1 class="ao-page-title">
            <i class="bi bi-box-seam-fill"></i> Đơn Hàng Được Giao
        </h1>
        <p class="ao-page-sub">Quản lý và xử lý các đơn hàng được phân công cho bạn</p>
    </div>
    <a asp-controller="Shipper" asp-action="Dashboard" class="ao-btn view" style="border-radius:10px;padding:9px 18px">
        <i class="bi bi-speedometer2"></i> Dashboard
    </a>
</div>

<!-- ── Toast Notifications ── -->
@if (TempData["Success"] is string successMsg)
{
    <div class="ao-toast-wrap">
        <div class="ao-alert success">
            <i class="bi bi-check-circle-fill"></i> @successMsg
        </div>
    </div>
}
@if (TempData["Error"] is string errorMsg)
{
    <div class="ao-toast-wrap">
        <div class="ao-alert error">
            <i class="bi bi-exclamation-circle-fill"></i> @errorMsg
        </div>
    </div>
}

<!-- ── Filter Tabs ── -->
<div class="ao-filter-bar">
    <a href="@Url.Action("AssignedOrders", "Shipper", new { filter = "all" })"
       class="ao-filter-btn @(f == "all" ? "active" : "")">
        <i class="bi bi-grid-3x3-gap"></i> Tất cả
        <span class="ao-filter-badge">@Model.TotalAll</span>
    </a>
    <a href="@Url.Action("AssignedOrders", "Shipper", new { filter = "assigned" })"
       class="ao-filter-btn @(f == "assigned" ? "active" : "")">
        <i class="bi bi-box-seam"></i> Chờ nhận
        <span class="ao-filter-badge">@Model.TotalAssigned</span>
    </a>
    <a href="@Url.Action("AssignedOrders", "Shipper", new { filter = "delivering" })"
       class="ao-filter-btn @(f == "delivering" ? "active" : "")">
        <i class="bi bi-truck"></i> Đang giao
        <span class="ao-filter-badge">@Model.TotalDelivering</span>
    </a>
</div>

<!-- ── Main Table Card ── -->
<div class="ao-table-card">
    <div class="ao-table-toolbar">
        <div class="ao-table-count">
            Hiển thị <strong>@Model.Orders.Count</strong> đơn hàng
            @if (f != "all")
            {
                <span>— filter: <strong>@(f == "assigned" ? "Chờ nhận" : "Đang giao")</strong></span>
            }
        </div>
        <div class="ao-search">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" placeholder="Tìm tên, SĐT, địa chỉ…" />
        </div>
    </div>

    @if (Model.Orders.Count == 0)
    {
        <div class="ao-empty">
            <i class="bi bi-inbox"></i>
            <p>Không có đơn hàng nào
                @if (f == "assigned") { <text>đang chờ nhận.</text> }
                else if (f == "delivering") { <text>đang được giao.</text> }
                else { <text>được phân công.</text> }
            </p>
        </div>
    }
    else
    {
        <div style="overflow-x:auto">
        <table class="ao-table" id="ordersTable">
            <thead>
                <tr>
                    <th>Đơn #</th>
                    <th>Khách hàng</th>
                    <th>Địa chỉ</th>
                    <th>Tổng tiền</th>
                    <th>Thanh toán</th>
                    <th>Trạng thái</th>
                    <th style="text-align:right">Thao tác</th>
                </tr>
            </thead>
            <tbody id="ordersBody">
            @foreach (var order in Model.Orders)
            {
                var hours = order.HoursSinceOrder;
                var urgencyClass = hours switch { > 24 => "critical", > 12 => "high", _ => "normal" };
                var urgencyTitle = hours switch { > 24 => "Quá hạn — giao gấp!", > 12 => "Hơn 12 giờ", _ => "Trong vòng 12 giờ" };
                var isAssigned = order.Status == OrderStatus.Shipped;
                var addressShort = order.ShippingAddress.Length > 40
                    ? order.ShippingAddress[..40] + "…"
                    : order.ShippingAddress;

                <tr data-search="@order.ShippingName.ToLower() @order.ShippingPhone @order.ShippingAddress.ToLower()">
                    <!-- Order ID -->
                    <td data-label="Đơn #">
                        <div class="ao-id">
                            #@order.OrderId
                            <small>@order.OrderDate.ToString("dd/MM HH:mm")</small>
                        </div>
                    </td>

                    <!-- Khách hàng -->
                    <td data-label="Khách hàng">
                        <div class="ao-customer-name">
                            <span class="ao-urgency @urgencyClass me-1" title="@urgencyTitle"></span>
                            @order.ShippingName
                        </div>
                        <div class="ao-customer-phone">
                            <i class="bi bi-telephone"></i> @order.ShippingPhone
                        </div>
                    </td>

                    <!-- Địa chỉ -->
                    <td data-label="Địa chỉ">
                        <span class="ao-address" title="@order.ShippingAddress">
                            @addressShort
                        </span>
                    </td>

                    <!-- Tổng tiền -->
                    <td data-label="Tổng tiền">
                        <span class="ao-total">@order.GrandTotal.ToString("N0") ₫</span>
                    </td>

                    <!-- Thanh toán -->
                    <td data-label="Thanh toán">
                        @if (order.IsPrepaid)
                        {
                            <span class="ao-pay paid">
                                <i class="bi bi-check-circle-fill"></i>
                                @(order.PaymentMethod ?? "Online") — Đã TT
                            </span>
                        }
                        else
                        {
                            <span class="ao-pay cod">
                                <i class="bi bi-cash-coin"></i>
                                COD — Thu tiền
                            </span>
                        }
                    </td>

                    <!-- Trạng thái -->
                    <td data-label="Trạng thái">
                        @if (isAssigned)
                        {
                            <span class="ao-status assigned">
                                <i class="bi bi-hourglass-split"></i> Chờ nhận
                            </span>
                        }
                        else
                        {
                            <span class="ao-status delivering">
                                <i class="bi bi-truck"></i> Đang giao
                            </span>
                        }
                    </td>

                    <!-- Thao tác -->
                    <td data-label="Thao tác" style="text-align:right">
                        <div class="ao-actions" style="justify-content:flex-end">
                            <!-- View Detail -->
                            <a asp-controller="Shipper" asp-action="DeliveryDetail"
                               asp-route-id="@order.OrderId"
                               class="ao-btn view"
                               title="Xem chi tiết đơn #@order.OrderId">
                                <i class="bi bi-arrow-right-short" style="font-size: 1.4rem"></i>
                            </a>

                            @if (isAssigned)
                            {
                                <!-- Accept -->
                                <form asp-action="AcceptOrder" asp-controller="Shipper" method="post" style="margin:0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="orderId" value="@order.OrderId" />
                                    <input type="hidden" name="returnFilter" value="@f" />
                                    <button type="submit" class="ao-btn accept"
                                            onclick="return confirm('Nhận đơn #@order.OrderId và bắt đầu giao?')">
                                        <i class="bi bi-check-lg"></i> Nhận đơn
                                    </button>
                                </form>

                                <!-- Reject -->
                                <button type="button" class="ao-btn reject"
                                        data-bs-toggle="modal"
                                        data-bs-target="#rejectModal"
                                        data-order-id="@order.OrderId"
                                        data-order-name="@order.ShippingName">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            }
                            else
                            {
                                <!-- Đang giao — chỉ xem -->
                                <span class="ao-btn disabled-btn" title="Đã nhận đơn, không thể hủy">
                                    <i class="bi bi-truck"></i> Đang giao
                                </span>
                            }
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }
</div>

<!-- ── Reject Confirm Modal ── -->
<div class="modal fade ao-modal-reject" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px">
        <div class="modal-content" style="border-radius:14px;border:none;box-shadow:0 20px 60px rgba(0,0,0,.15)">
            <div class="modal-header px-4 pt-4 pb-3">
                <h5 class="modal-title fw-700" style="font-size:1rem">
                    <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                    Từ chối đơn hàng?
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 py-3">
                <p class="mb-0" style="font-size:.9rem;color:#595959">
                    Bạn sắp từ chối đơn <strong id="rejectOrderLabel"></strong>.
                    Đơn sẽ được trả về để phân bổ lại cho shipper khác.
                </p>
            </div>
            <div class="modal-footer px-4 pb-4 pt-3 gap-2" style="border:none">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal"
                        style="border-radius:8px;font-size:.875rem">
                    Hủy bỏ
                </button>
                <form id="rejectForm" asp-action="RejectOrder" asp-controller="Shipper" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="rejectOrderId" name="orderId" value="" />
                    <input type="hidden" name="returnFilter" value="@f" />
                    <button type="submit" class="btn"
                            style="background:#ff4d4f;color:#fff;border-radius:8px;font-size:.875rem;font-weight:600">
                        <i class="bi bi-x-circle me-1"></i> Từ chối đơn
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Populate Reject Modal ──────────────────────────────────
    document.getElementById('rejectModal').addEventListener('show.bs.modal', function (e) {
        const btn     = e.relatedTarget;
        const orderId = btn.getAttribute('data-order-id');
        const name    = btn.getAttribute('data-order-name');
        document.getElementById('rejectOrderId').value    = orderId;
        document.getElementById('rejectOrderLabel').textContent = `#${orderId} (${name})`;
    });

    // ── Client-side search ────────────────────────────────────
    document.getElementById('searchInput').addEventListener('input', function () {
        const q = this.value.toLowerCase().trim();
        document.querySelectorAll('#ordersBody tr').forEach(row => {
            const s = row.getAttribute('data-search') || '';
            row.style.display = s.includes(q) ? '' : 'none';
        });
    });

    // ── Auto-hide toast ───────────────────────────────────────
    document.querySelectorAll('.ao-alert').forEach(el => {
        setTimeout(() => {
            el.style.transition = 'opacity .4s';
            el.style.opacity = '0';
            setTimeout(() => el.closest('.ao-toast-wrap').remove(), 400);
        }, 4000);
    });
</script>
}
