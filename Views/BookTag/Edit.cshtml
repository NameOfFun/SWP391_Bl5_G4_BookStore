@model BookStore.Dtos.Common.BookTagDto
@{
    ViewData["Title"] = "Sửa Tag";
    ViewData["BreadcrumbParent"] = "Tag Sách";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "BookTag");
}

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
        <div class="card border-0 shadow-sm" style="border-radius:10px">
            <div class="card-header bg-white border-0 px-4 pt-4 pb-0">
                <h5 class="mb-0 fw-600" style="font-size:1rem;color:#262626">
                    <i class="bi bi-pencil-square me-2 text-primary"></i>Sửa Tag
                </h5>
            </div>
            <div class="card-body px-4 py-4">
                <form asp-action="Edit" asp-route-id="@Model.TagId" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label" style="font-size:.875rem;font-weight:500;color:#595959">
                            Tên Tag <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control" style="border-radius:6px;font-size:.875rem"
                               placeholder="Nhập tên tag (vd: LậpTrình, TiểuThuyết...)" />
                        <span asp-validation-for="Name" class="text-danger" style="font-size:.8rem"></span>
                        <div class="mt-1" style="font-size:.78rem;color:#8c8c8c">
                            <i class="bi bi-info-circle me-1"></i>Hệ thống sẽ tự động thêm <strong>#</strong> vào trước tên tag. Tối đa 99 ký tự.
                        </div>
                    </div>

                    <div class="mb-4 p-3 rounded" style="background:#fafafa;border:1px solid #f0f0f0">
                        <span style="font-size:.8rem;color:#8c8c8c">Trạng thái hiện tại:</span>
                        @if (Model.IsActive)
                        {
                            <span class="ms-2 badge rounded-pill" style="background:#f6ffed;color:#52c41a;border:1px solid #b7eb8f;font-size:.78rem">
                                <i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>Đang hoạt động
                            </span>
                        }
                        else
                        {
                            <span class="ms-2 badge rounded-pill" style="background:#fff2f0;color:#ff4d4f;border:1px solid #ffccc7;font-size:.78rem">
                                <i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>Đã vô hiệu hóa
                            </span>
                        }
                        <div class="mt-1" style="font-size:.78rem;color:#8c8c8c">
                            Để thay đổi trạng thái, dùng nút bật/tắt trong danh sách.
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" style="border-radius:6px;font-size:.875rem;padding:8px 20px">
                            <i class="bi bi-check-lg me-1"></i>Lưu Thay Đổi
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:6px;font-size:.875rem;padding:8px 20px">
                            Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
