@model IReadOnlyList<BookStore.Dtos.Common.BookDto>
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@using BookStore.Dtos.Common
@using BookStore.Helpers
@{
    string MixFilterClass(BookDto b)
    {
        var name = b.CategoryName ?? "";
        var kids = name.Contains("thiếu nhi", StringComparison.OrdinalIgnoreCase)
            || name.Contains("teen", StringComparison.OrdinalIgnoreCase);
        return kids ? "mix category-item books kids-teens" : "mix category-item books adults";
    }

    string Excerpt(string? description, int maxLen = 100)
    {
        if (string.IsNullOrEmpty(description)) return "";
        var t = description.Trim();
        return t.Length <= maxLen ? t : t[..maxLen].TrimEnd() + "…";
    }
}
<!-- Start: Category Filter / New Releases (template: wwwroot/index.html) -->
<section class="category-filter section-padding bookstore-home-new-releases">
    <div class="container">
        <div class="center-content">
            <div class="row">
                <div class="col-md-6 col-md-offset-3">
                    <h2 class="section-title">Sách mới phát hành</h2>
                    <span class="underline center"></span>
                    <p class="lead">Khám phá các tựa sách và ấn phẩm mới được cập nhật thường xuyên tại BookStore.</p>
                </div>
            </div>
        </div>
        <div class="filter-buttons">
            <div class="filter btn" data-filter="all">Tất cả</div>
            <div class="filter btn" data-filter=".adults">Người lớn</div>
            <div class="filter btn" data-filter=".kids-teens">Thiếu nhi &amp; teen</div>
            <div class="filter btn" data-filter=".video">Video</div>
            <div class="filter btn" data-filter=".audio">Âm thanh</div>
            <div class="filter btn" data-filter=".books">Sách</div>
            <div class="filter btn" data-filter=".magazines">Tạp chí</div>
        </div>
    </div>
    <div id="category-filter">
        <ul class="category-list">
            @if (Model.Count == 0)
            {
                <li class="mix category-item books bookstore-home-new-releases-empty">
                    Chưa có sách hoạt động trong hệ thống. Hãy thêm sách từ quản trị.
                </li>
            }
            else
            {
                foreach (var book in Model)
                {
                    var cover = BookCoverHelper.ResolveCoverPath(Env, book.BookId, book.ImageUrl);
                    var isbn = $"978-604-{book.BookId:D6}";
                    var excerpt = Excerpt(book.Description);
                    var price = book.PromotionalPrice ?? book.Price;
                    <li class="@MixFilterClass(book)">
                        <figure>
                            <img src="@cover" alt="@book.Title" />
                            <figcaption class="bg-orange">
                                <div class="info-block">
                                    <h4>@book.Title</h4>
                                    <span class="author"><strong>Tác giả:</strong> @(book.AuthorName ?? "—")</span>
                                    <span class="author"><strong>ISBN:</strong> @isbn</span>
                                    @if (!string.IsNullOrEmpty(book.CategoryName))
                                    {
                                        <span class="author"><strong>Danh mục:</strong> @book.CategoryName</span>
                                    }
                                    <span class="author"><strong>Giá:</strong> @price.ToString("N0") đ</span>
                                    <div class="rating">
                                        <span>☆</span><span>☆</span><span>☆</span><span>☆</span><span>☆</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(excerpt))
                                    {
                                        <p>@excerpt</p>
                                    }
                                    <a asp-controller="Book" asp-action="Details" asp-route-id="@book.BookId">Xem thêm <i class="fa fa-long-arrow-right"></i></a>
                                    <ol>
                                        <li><a href="#"><i class="fa fa-shopping-cart"></i></a></li>
                                        <li><a href="#"><i class="fa fa-heart"></i></a></li>
                                        <li><a href="#"><i class="fa fa-envelope"></i></a></li>
                                        <li><a href="#"><i class="fa fa-share-alt"></i></a></li>
                                        <li><a asp-controller="Book" asp-action="Details" asp-route-id="@book.BookId"><i class="fa fa-search"></i></a></li>
                                    </ol>
                                </div>
                            </figcaption>
                        </figure>
                    </li>
                }
            }
        </ul>
        <div class="center-content">
            <a asp-controller="Book" asp-action="Shop" class="btn btn-primary">Xem thêm</a>
        </div>
        <div class="clearfix"></div>
    </div>
</section>
<!-- End: Category Filter -->
