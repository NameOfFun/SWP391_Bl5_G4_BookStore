@model BookStore.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
    ViewData["LibrariaInnerHeader"] = false;
    ViewData["HideLibrariaSocial"] = true;
    ViewData["LibrariaBodyClass"] = "libraria-page-home";
}

@* Thứ tự: Header → Slider (HomeSlider CRUD) → Tìm kiếm → Sách mới → Footer *@
<main class="bookstore-home-v1">
@await Html.PartialAsync("Partials/_HomeHero", Model.Sliders)
@await Html.PartialAsync("Partials/_HomeLibrarySearch", Model)
@await Html.PartialAsync("Partials/_HomeNewReleases", Model.NewBooks)
</main>
