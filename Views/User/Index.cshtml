@using BookStore.Dtos.Admin.User
@using Microsoft.AspNetCore.Mvc.Rendering
@model IReadOnlyList<UserListDto>
@{
    ViewData["Title"] = "Quản lý người dùng";
    ViewData["BreadcrumbParent"] = "Quản lý người dùng";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "User");
    var allRoles = (ViewBag.AllRolesForFilter as List<SelectListItem>) ?? new List<SelectListItem>();
}

<style>
    .book-management-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    .book-management-header h4 {
        font-weight: 600;
        font-size: 1.25rem;
        color: #1a1a2e;
        margin: 0;
    }
    .filter-card {
        background: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 10px;
        padding: 16px 20px;
        margin-bottom: 20px;
    }
    .filter-row {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }
    .search-group {
        display: flex;
        flex: 1;
        min-width: 250px;
        gap: 0;
    }
    .search-group .form-control {
        border-radius: 6px 0 0 6px;
        border-right: none;
        font-size: 0.875rem;
        border-color: #d9d9d9;
    }
    .search-group .form-control:focus {
        box-shadow: none;
        border-color: #1677ff;
    }
    .search-group .btn-search {
        border-radius: 0 6px 6px 0;
        background-color: #1677ff;
        border-color: #1677ff;
        color: #fff;
        font-size: 0.875rem;
        padding: 6px 16px;
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }
    .search-group .btn-search:hover { background-color: #0958d9; border-color: #0958d9; }
    .filter-select {
        font-size: 0.875rem;
        border-color: #d9d9d9;
        border-radius: 6px;
        color: #595959;
        min-width: 140px;
        padding: 6px 10px;
    }
    .filter-select:focus { box-shadow: none; border-color: #1677ff; }
    .book-table-card {
        background: #fff;
        border: 1px solid #e8e8e8;
        border-radius: 10px;
        overflow: hidden;
    }
    .book-table {
        margin: 0;
        font-size: 0.875rem;
    }
    .book-table thead tr th {
        background-color: #fafafa;
        color: #595959;
        font-weight: 600;
        font-size: 0.8125rem;
        padding: 12px 14px;
        border-bottom: 1px solid #e8e8e8;
        border-top: none;
        white-space: nowrap;
    }
    .book-table tbody tr td {
        padding: 12px 14px;
        border-bottom: 1px solid #f0f0f0;
        vertical-align: middle;
        color: #262626;
    }
    .book-table tbody tr:last-child td { border-bottom: none; }
    .book-table tbody tr:hover { background-color: #fafafa; }
    .badge-active {
        background-color: #f6ffed;
        color: #52c41a;
        border: 1px solid #b7eb8f;
        font-weight: 500;
        font-size: 0.75rem;
        padding: 3px 10px;
        border-radius: 20px;
    }
    .badge-inactive {
        background-color: #fff2f0;
        color: #ff4d4f;
        border: 1px solid #ffccc7;
        font-weight: 500;
        font-size: 0.75rem;
        padding: 3px 10px;
        border-radius: 20px;
    }
    .btn-action {
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        font-size: 0.875rem;
        border: 1px solid;
    }
    .btn-edit { color: #fa8c16; border-color: #ffd591; background: #fff; }
    .btn-edit:hover { background: #fff7e6; color: #fa8c16; border-color: #fa8c16; }
    .btn-deactivate { color: #8c8c8c; border-color: #d9d9d9; background: #fff; }
    .btn-deactivate:hover { background: #f5f5f5; border-color: #8c8c8c; }
    .btn-activate { color: #52c41a; border-color: #b7eb8f; background: #fff; }
    .btn-activate:hover { background: #f6ffed; border-color: #52c41a; }
    .btn-add-new {
        background-color: #1677ff;
        border-color: #1677ff;
        font-size: 0.875rem;
        padding: 7px 18px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .btn-add-new:hover { background-color: #0958d9; border-color: #0958d9; }
    .pagination-area {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 16px;
        border-top: 1px solid #f0f0f0;
        font-size: 0.875rem;
        color: #595959;
    }
    .pagination-controls { display: flex; gap: 4px; align-items: center; }
    .page-btn {
        min-width: 32px;
        height: 32px;
        border: 1px solid #d9d9d9;
        background: #fff;
        color: #262626;
        border-radius: 6px;
        font-size: 0.8125rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 6px;
        transition: all .15s;
    }
    .page-btn:hover:not(:disabled) { border-color: #1677ff; color: #1677ff; }
    .page-btn.active { background: #1677ff; border-color: #1677ff; color: #fff; }
    .page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .empty-state {
        text-align: center;
        padding: 48px 20px;
        color: #8c8c8c;
    }
    .empty-state i { font-size: 2.5rem; display: block; margin-bottom: 10px; color: #d9d9d9; }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="book-management-header">
    <h4>Quản lý người dùng</h4>
    <a asp-action="Create" class="btn btn-primary btn-add-new">
        <i class="bi bi-plus-lg"></i> Thêm người dùng
    </a>
</div>

<div class="filter-card">
    <div class="filter-row">
        <div class="search-group">
            <input type="text" id="searchInput" class="form-control" placeholder="Tìm theo tên hoặc email...">
            <button class="btn btn-search" onclick="applyFilters()">
                <i class="bi bi-search"></i> Tìm kiếm
            </button>
        </div>
        <select class="form-select filter-select" id="filterRole" onchange="applyFilters()">
            <option value="">Filter theo vai trò</option>
            @foreach (var role in allRoles)
            {
                <option value="@role.Value?.ToLower()">@role.Text</option>
            }
        </select>
        <select class="form-select filter-select" id="filterStatus" onchange="applyFilters()">
            <option value="">Filter theo trạng thái</option>
            <option value="active">Active</option>
            <option value="inactive">Deactive</option>
        </select>
    </div>
</div>

<div class="book-table-card">
    <table class="table book-table" id="userTable">
        <thead>
            <tr>
                <th style="width:52px">STT</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th style="width:140px">Số điện thoại</th>
                <th style="width:160px">Vai trò</th>
                <th class="text-center" style="width:100px">Trạng thái</th>
                <th class="text-center" style="width:90px">Thao tác</th>
            </tr>
        </thead>
        <tbody id="userTableBody">
            @{int stt = 0;}
            @foreach (var user in Model)
            {
                stt++;
                <tr class="user-row"
                    data-name="@user.Name.ToLower()"
                    data-email="@(user.Email?.ToLower() ?? "")"
                    data-role="@user.RolesDisplay.ToLower()"
                    data-status="@(user.IsActive ? "active" : "inactive")">
                    <td class="row-stt">@stt</td>
                    <td>
                        <span class="fw-semibold">@(string.IsNullOrEmpty(user.Name) ? "—" : user.Name)</span>
                    </td>
                    <td>@(user.Email ?? "—")</td>
                    <td>@(user.PhoneNumber ?? "—")</td>
                    <td>
                        @foreach (var role in user.Roles)
                        {
                            <span class="badge bg-light text-dark border me-1" style="font-size:.75rem">@role</span>
                        }
                        @if (!user.Roles.Any())
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td class="text-center">
                        @if (user.IsActive)
                        {
                            <span class="badge-active">Active</span>
                        }
                        else
                        {
                            <span class="badge-inactive">Deactive</span>
                        }
                    </td>
                    <td class="text-center">
                        <div class="d-flex gap-1 justify-content-center">
                            @if (!user.Roles.Contains("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@user.Id"
                                   class="btn-action btn-edit" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="ToggleActive" asp-route-id="@user.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('@(user.IsActive ? "Vô hiệu hóa tài khoản này?" : "Kích hoạt tài khoản này?")')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn-action @(user.IsActive ? "btn-deactivate" : "btn-activate")"
                                            title="@(user.IsActive ? "Vô hiệu hóa" : "Kích hoạt")">
                                        <i class="bi @(user.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small" title="Tài khoản Admin được bảo vệ">
                                    <i class="bi bi-shield-lock"></i>
                                </span>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div id="emptyState" class="empty-state" style="display:none">
        <i class="bi bi-people"></i>
        Không tìm thấy người dùng nào
    </div>

    <div class="pagination-area">
        <span class="pagination-info" id="pageInfo">Hiển thị 0 bản ghi</span>
        <div class="pagination-controls" id="paginationControls"></div>
    </div>
</div>

<script>
    const PAGE_SIZE = 10;
    let currentPage = 1;
    let filteredRows = [];

    function applyFilters() {
        const search = document.getElementById('searchInput').value.toLowerCase().trim();
        const roleFilter = document.getElementById('filterRole').value.toLowerCase();
        const statusFilter = document.getElementById('filterStatus').value;

        const allRows = Array.from(document.querySelectorAll('.user-row'));

        filteredRows = allRows.filter(row => {
            const name = row.dataset.name || '';
            const email = row.dataset.email || '';
            const role = row.dataset.role || '';
            const status = row.dataset.status || '';

            if (search && !name.includes(search) && !email.includes(search)) return false;
            if (statusFilter && status !== statusFilter) return false;
            if (roleFilter && !role.includes(roleFilter)) return false;
            return true;
        });

        allRows.forEach(r => r.style.display = 'none');
        currentPage = 1;
        renderPage();
    }

    function renderPage() {
        const total = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        if (currentPage > totalPages) currentPage = totalPages;

        const start = (currentPage - 1) * PAGE_SIZE;
        const end = Math.min(start + PAGE_SIZE, total);

        filteredRows.forEach((r, i) => {
            r.style.display = (i >= start && i < end) ? '' : 'none';
            if (i >= start && i < end) {
                r.querySelector('.row-stt').textContent = start + (i - start) + 1;
            }
        });

        const emptyState = document.getElementById('emptyState');
        emptyState.style.display = total === 0 ? '' : 'none';

        const info = document.getElementById('pageInfo');
        if (total === 0) {
            info.textContent = 'Không có bản ghi nào';
        } else {
            info.textContent = `Hiển thị ${start + 1}–${end} của ${total} bản ghi`;
        }

        renderPagination(totalPages);
    }

    function renderPagination(totalPages) {
        const container = document.getElementById('paginationControls');
        container.innerHTML = '';

        const prev = document.createElement('button');
        prev.className = 'page-btn';
        prev.textContent = 'Trước';
        prev.disabled = currentPage === 1;
        prev.onclick = () => { currentPage--; renderPage(); };
        container.appendChild(prev);

        const maxVisible = 5;
        let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
        let endPage = Math.min(totalPages, startPage + maxVisible - 1);
        if (endPage - startPage < maxVisible - 1) startPage = Math.max(1, endPage - maxVisible + 1);

        for (let i = startPage; i <= endPage; i++) {
            const btn = document.createElement('button');
            btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
            btn.textContent = i;
            const page = i;
            btn.onclick = () => { currentPage = page; renderPage(); };
            container.appendChild(btn);
        }

        const next = document.createElement('button');
        next.className = 'page-btn';
        next.textContent = 'Sau';
        next.disabled = currentPage === totalPages;
        next.onclick = () => { currentPage++; renderPage(); };
        container.appendChild(next);
    }

    document.getElementById('searchInput').addEventListener('keydown', function (e) {
        if (e.key === 'Enter') applyFilters();
    });

    document.addEventListener('DOMContentLoaded', function () {
        filteredRows = Array.from(document.querySelectorAll('.user-row'));
        renderPage();
    });
</script>
