@using BookStore.Dtos.Admin.User
@model EditUserDto
@{
    ViewData["Title"] = "Chỉnh sửa người dùng";
    ViewData["BreadcrumbParent"] = "Tài Khoản và Vai Trò";
    ViewData["BreadcrumbParentUrl"] = Url.Action("Index", "User");
}

<style>
    .form-card { background:#fff; border:1px solid #e8e8e8; border-radius:10px; overflow:hidden; max-width:760px; margin:0 auto; }
    .form-card-header { padding:16px 24px; border-bottom:1px solid #e8e8e8; }
    .form-card-header h5 { font-weight:600; font-size:1rem; color:#1a1a2e; margin:0; }
    .form-card-body { padding:24px; }
    .field-label { font-size:.8rem; font-weight:500; color:#595959; margin-bottom:5px; }
    .form-control, .form-select { font-size:.875rem; border-radius:6px; border-color:#d9d9d9; }
    .form-control:focus, .form-select:focus { border-color:#1677ff; box-shadow:0 0 0 .2rem rgba(22,119,255,.15); }
    .field-hint { font-size:.775rem; color:#8c8c8c; margin-top:4px; }
    .form-divider { border:none; border-top:1px solid #f0f0f0; margin:20px 0; }
    .section-title { font-size:.8125rem; font-weight:600; color:#595959; text-transform:uppercase; letter-spacing:.04em; margin-bottom:12px; }
    .switch-label { font-size:.875rem; font-weight:500; color:#262626; }
    .btn-save { background-color:#fa8c16; border-color:#fa8c16; font-size:.875rem; padding:7px 20px; border-radius:6px; }
    .btn-save:hover { background-color:#d46b08; border-color:#d46b08; }
    .btn-cancel { font-size:.875rem; padding:7px 16px; border-radius:6px; }
</style>

<div class="book-management-header" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
    <h4 style="font-weight:600;font-size:1.25rem;color:#1a1a2e;margin:0">Chỉnh sửa người dùng</h4>
</div>

<div class="form-card">
    <div class="form-card-header">
        <h5>Thông tin người dùng</h5>
    </div>
    <div class="form-card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="font-size:.875rem;border-radius:6px"></div>

            <div class="mb-3">
                <label class="field-label">Họ và tên <span class="text-danger">*</span></label>
                <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên..." />
                <span asp-validation-for="FullName" class="text-danger" style="font-size:.775rem"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="field-label">Email <span class="text-danger">*</span></label>
                    <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                    <span asp-validation-for="Email" class="text-danger" style="font-size:.775rem"></span>
                </div>
                <div class="col-md-6">
                    <label class="field-label">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="0xxxxxxxxx" />
                    <span asp-validation-for="PhoneNumber" class="text-danger" style="font-size:.775rem"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="field-label">Vai trò <span class="text-danger">*</span></label>
                <select asp-for="SelectedRole" asp-items="Model.AvailableRoles" class="form-select">
                    <option value="">-- Chọn vai trò --</option>
                </select>
                <span asp-validation-for="SelectedRole" class="text-danger" style="font-size:.775rem"></span>
            </div>

            <div class="mb-3">
                <label class="field-label d-block">Trạng thái</label>
                <div class="form-check form-switch mt-1">
                    <input class="form-check-input" type="checkbox" asp-for="IsActive" id="isActiveSwitch" />
                    <label class="form-check-label switch-label" for="isActiveSwitch">Kích hoạt tài khoản</label>
                </div>
                <div class="field-hint">Bỏ chọn để vô hiệu hóa đăng nhập của tài khoản này.</div>
            </div>

            <hr class="form-divider" />
            <div class="section-title">Đặt lại mật khẩu <span style="font-weight:400;text-transform:none;letter-spacing:0;color:#8c8c8c">(tùy chọn)</span></div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="field-label">Mật khẩu mới</label>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="Tối thiểu 6 ký tự" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger" style="font-size:.775rem"></span>
                </div>
                <div class="col-md-6">
                    <label class="field-label">Xác nhận mật khẩu mới</label>
                    <input asp-for="ConfirmNewPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu mới" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger" style="font-size:.775rem"></span>
                </div>
            </div>
            <div class="field-hint mb-3">Để trống nếu không muốn thay đổi mật khẩu.</div>

            <hr class="form-divider" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning btn-save text-white">
                    <i class="bi bi-floppy me-1"></i> Cập nhật
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-cancel">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
