@model BookStore.Dtos.Common.BookDto
@{
    ViewData["Title"] = "Xóa sách";
}

<div class="container mt-4" style="max-width:640px">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Quản lý Sách</a></li>
            <li class="breadcrumb-item active">Xóa</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Xác nhận xóa sách</h5>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                Bạn có chắc muốn xóa sách <strong>"@Model.Title"</strong> không?
                Hành động này sẽ ẩn sách khỏi cửa hàng (có thể khôi phục lại bằng cách chỉnh sửa).
            </div>

            <div class="d-flex gap-3 align-items-start">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Title" class="rounded border"
                         style="width:80px;height:110px;object-fit:cover;flex-shrink:0;" />
                }

                <dl class="row mb-0 flex-grow-1">
                    <dt class="col-sm-4">Tiêu đề</dt>
                    <dd class="col-sm-8">@Model.Title</dd>

                    <dt class="col-sm-4">Tác giả</dt>
                    <dd class="col-sm-8">@(Model.AuthorName ?? "—")</dd>

                    <dt class="col-sm-4">Danh mục</dt>
                    <dd class="col-sm-8">@(Model.CategoryName ?? "—")</dd>

                    <dt class="col-sm-4">Giá bán</dt>
                    <dd class="col-sm-8">@Model.Price.ToString("N0") đ</dd>

                    <dt class="col-sm-4">Tồn kho</dt>
                    <dd class="col-sm-8">@Model.Stock</dd>
                </dl>
            </div>
        </div>
        <div class="card-footer bg-transparent d-flex gap-2">
            <form asp-action="Delete" asp-route-id="@Model.BookId" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-trash me-1"></i> Xác nhận xóa
                </button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </div>
    </div>
</div>
