@model BookStore.Dtos.Common.BookDto
@{
    var cover = BookCoverHelper.ResolveCoverPath(Model.ImageUrl);
    var price = Model.EffectivePrice;
    var oldPrice = Model.IsPromoActive ? Model.Price : (decimal?)null;
    var excerpt = Model.Description;
    if (!string.IsNullOrEmpty(excerpt) && excerpt.Length > 220)
        excerpt = excerpt[..220] + "…";
    var isbn = $"978-604-{Model.BookId:D6}";
}
<article>
    <div class="single-book-box">
        <div class="post-thumbnail">
            <div class="book-list-icon yellow-icon"></div>
            <a asp-action="Details" asp-route-id="@Model.BookId">
                <img alt="@Model.Title" src="@cover" />
            </a>
        </div>
        <div class="post-detail">
            <header class="entry-header">
                <div class="row">
                    <div class="col-sm-6">
                        <h3 class="entry-title">
                            <a asp-action="Details" asp-route-id="@Model.BookId">@Model.Title</a>
                        </h3>
                        <ul>
                            <li><strong>Tác giả:</strong> @(Model.AuthorName ?? "—")</li>
                            <li><strong>ISBN:</strong> @isbn</li>
                        </ul>
                    </div>
                    <div class="col-sm-6">
                        <ul>
                            <li><strong>Danh mục:</strong> @(Model.CategoryName ?? "—")</li>
                            <li><strong>Giá:</strong> @price.ToString("N0") đ @if (oldPrice.HasValue) { <span class="text-muted" style="text-decoration:line-through;font-size:12px">@oldPrice.Value.ToString("N0") đ</span> }</li>
                            <li>
                                <div class="rating">
                                    <strong>Đánh giá: </strong>
                                    <span class="fa fa-star" style="color:#ff7236"></span>
                                    <span class="fa fa-star" style="color:#ff7236"></span>
                                    <span class="fa fa-star" style="color:#ff7236"></span>
                                    <span class="fa fa-star-half-o" style="color:#ff7236"></span>
                                    <span class="fa fa-star-o" style="color:#ccc"></span>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>
            @if (!string.IsNullOrEmpty(excerpt))
            {
                <div class="entry-content">
                    <p>@excerpt</p>
                </div>
            }
            <footer class="entry-footer">
                <a class="btn btn-dark-gray" asp-action="Details" asp-route-id="@Model.BookId">Xem chi tiết</a>
            </footer>
        </div>
        <div class="clear"></div>
    </div>
</article>
