@model BookStore.Dtos.Common.BookDto
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@{
    var cover = BookCoverHelper.ResolveCoverPath(Env, Model.BookId, Model.ImageUrl);
    var price = Model.PromotionalPrice ?? Model.Price;
    var isbn = $"978-604-{Model.BookId:D6}";
}
<li>
    <figure class="bookshop-grid-cover">
        <img src="@cover" alt="@Model.Title" />
        <figcaption>
            <p><strong>@Model.Title</strong></p>
            <p><strong>Tác giả:</strong> @(Model.AuthorName ?? "—")</p>
        </figcaption>
    </figure>
    <div class="book-list-icon blue-icon"></div>
    <div class="single-book-box">
        <div class="post-detail">
            <header class="entry-header">
                <h3 class="entry-title"><a asp-action="Details" asp-route-id="@Model.BookId">@Model.Title</a></h3>
                <ul>
                    <li><strong>Tác giả:</strong> @(Model.AuthorName ?? "—")</li>
                    <li><strong>ISBN:</strong> @isbn</li>
                </ul>
            </header>
            <div class="entry-content">
                <p><strong class="text-primary" style="font-size:16px">@price.ToString("N0") đ</strong></p>
            </div>
            <footer class="entry-footer">
                <a class="btn btn-primary" asp-action="Details" asp-route-id="@Model.BookId">Xem chi tiết</a>
            </footer>
        </div>
    </div>
</li>
