@model BookStore.Dtos.Common.BookDto
@{
    ViewData["Title"] = "Thêm sách mới";
}

<div class="container mt-4" style="max-width:860px">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Quản lý Sách</a></li>
            <li class="breadcrumb-item active">Thêm mới</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Thêm sách mới</h5>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                <div class="row g-3">
                    @* Tiêu đề *@
                    <div class="col-12">
                        <label asp-for="Title" class="form-label fw-semibold">Tiêu đề <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề sách..." />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    @* Mô tả *@
                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="4"
                                  placeholder="Nhập mô tả ngắn về sách..."></textarea>
                    </div>

                    @* Tác giả & Danh mục *@
                    <div class="col-md-6">
                        <label asp-for="AuthorName" class="form-label fw-semibold">Tác giả</label>
                        <input asp-for="AuthorName" class="form-control" placeholder="Nhập tên tác giả..." />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label fw-semibold">Danh mục</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                    </div>

                    @* Giá & Tồn kho *@
                    <div class="col-md-4">
                        <label asp-for="Price" class="form-label fw-semibold">Giá bán (đ) <span class="text-danger">*</span></label>
                        <input asp-for="Price" class="form-control" type="number" min="0" step="1000" placeholder="0" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="PromotionalPrice" class="form-label fw-semibold">Giá khuyến mãi (đ)</label>
                        <input asp-for="PromotionalPrice" class="form-control" type="number" min="0" step="1000" placeholder="Để trống nếu không có" />
                        <span asp-validation-for="PromotionalPrice" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Stock" class="form-label fw-semibold">Tồn kho</label>
                        <input asp-for="Stock" class="form-control" type="number" min="0" placeholder="0" />
                        <span asp-validation-for="Stock" class="text-danger small"></span>
                    </div>

                    @* Ngày khuyến mãi *@
                    <div class="col-md-6">
                        <label asp-for="PromotionalStartsAt" class="form-label fw-semibold">KM từ ngày</label>
                        <input asp-for="PromotionalStartsAt" class="form-control" type="datetime-local" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PromotionalEndsAt" class="form-label fw-semibold">KM đến ngày</label>
                        <input asp-for="PromotionalEndsAt" class="form-control" type="datetime-local" />
                    </div>

                    @* Ảnh bìa: URL hoặc file trên máy *@
                    <div class="col-12">
                        <label class="form-label fw-semibold">Ảnh bìa</label>
                        <p class="small text-muted mb-2">Dán link ảnh trên internet, hoặc chọn file từ máy (lưu vào thư mục <code>wwwroot/image/cover</code>). Nếu chọn file, ảnh upload sẽ được ưu tiên hơn link.</p>
                        <label asp-for="ImageUrl" class="form-label small">Đường dẫn / URL ảnh</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://... hoặc để trống nếu chỉ upload file" id="imageUrlInput" />
                        <label for="coverImage" class="form-label small mt-3">Chọn ảnh từ máy tính</label>
                        <input type="file" name="coverImage" id="coverImage" class="form-control" accept="image/jpeg,image/png,image/webp,image/gif" />
                        <div id="imagePreview" class="mt-2 d-none">
                            <img id="previewImg" src="" alt="Xem trước" class="rounded border"
                                 style="max-height:180px;object-fit:contain;" />
                        </div>
                    </div>
                </div>

                <hr class="my-4" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-floppy me-1"></i> Lưu
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            var urlInput = document.getElementById('imageUrlInput');
            var fileInput = document.getElementById('coverImage');
            var preview = document.getElementById('imagePreview');
            var img = document.getElementById('previewImg');
            function showUrlPreview() {
                var url = urlInput.value.trim();
                if (url && (!fileInput.files || !fileInput.files.length)) {
                    img.src = url;
                    preview.classList.remove('d-none');
                } else if (!fileInput.files || !fileInput.files.length) {
                    preview.classList.add('d-none');
                }
            }
            urlInput.addEventListener('input', showUrlPreview);
            fileInput.addEventListener('change', function () {
                if (this.files && this.files[0]) {
                    img.src = URL.createObjectURL(this.files[0]);
                    preview.classList.remove('d-none');
                } else {
                    showUrlPreview();
                }
            });
        })();
    </script>
}
