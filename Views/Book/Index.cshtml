@model IReadOnlyList<BookStore.Dtos.Common.BookDto>
@{
    ViewData["Title"] = "Quản lý Sách";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-book me-2"></i>Quản lý Sách</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Thêm sách mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width:60px">#</th>
                        <th style="width:80px">Ảnh</th>
                        <th>Tiêu đề</th>
                        <th>Tác giả</th>
                        <th>Danh mục</th>
                        <th class="text-end">Giá (đ)</th>
                        <th class="text-center">Tồn kho</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center" style="width:160px">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model)
                    {
                        <tr>
                            <td>@book.BookId</td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(book.ImageUrl))
                                {
                                    <img src="@book.ImageUrl" alt="@book.Title"
                                         class="rounded" style="width:48px;height:64px;object-fit:cover;" />
                                }
                                else
                                {
                                    <span class="text-muted"><i class="bi bi-image fs-4"></i></span>
                                }
                            </td>
                            <td>
                                <strong>@book.Title</strong>
                                @if (!string.IsNullOrEmpty(book.Description))
                                {
                                    <br /><small class="text-muted">
                                        @(book.Description.Length > 80 ? book.Description[..80] + "…" : book.Description)
                                    </small>
                                }
                            </td>
                            <td>@(book.AuthorName ?? "—")</td>
                            <td>@(book.CategoryName ?? "—")</td>
                            <td class="text-end">
                                @if (book.PromotionalPrice.HasValue)
                                {
                                    <span class="text-decoration-line-through text-muted small">
                                        @book.Price.ToString("N0")
                                    </span><br />
                                    <span class="text-danger fw-bold">@book.PromotionalPrice.Value.ToString("N0")</span>
                                }
                                else
                                {
                                    @book.Price.ToString("N0")
                                }
                            </td>
                            <td class="text-center">
                                @if (book.Stock <= 5)
                                {
                                    <span class="badge bg-danger">@book.Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@book.Stock</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (book.IsActive)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ẩn</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@book.BookId"
                                   class="btn btn-sm btn-outline-info" title="Chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@book.BookId"
                                   class="btn btn-sm btn-warning" title="Sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@book.BookId"
                                   class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-3 d-block mb-1"></i>
                                Chưa có sách nào
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
