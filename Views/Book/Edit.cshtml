@model BookStore.Dtos.Common.BookDto
@{
    ViewData["Title"] = "Chỉnh sửa sách";
    bool canSetPrice = User.IsInRole("Manager");
}

<div class="container mt-4" style="max-width:860px">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Quản lý Sách</a></li>
            <li class="breadcrumb-item active">Chỉnh sửa</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-header bg-warning">
            <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa sách</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.BookId" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="BookId" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Title" class="form-label fw-semibold">Tiêu đề <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" maxlength="100" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="4" maxlength="255"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="AuthorName" class="form-label fw-semibold">Tác giả</label>
                        <input asp-for="AuthorName" class="form-control" placeholder="Nhập tên tác giả..." maxlength="100" />
                        <span asp-validation-for="AuthorName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label fw-semibold">Danh mục</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                    </div>

                    @if (canSetPrice)
                    {
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label fw-semibold">Giá bán (đ) <span class="text-danger">*</span></label>
                            <input asp-for="Price" class="form-control" type="number" min="0" step="any" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PromotionalPrice" class="form-label fw-semibold">Giá khuyến mãi (đ)</label>
                            <input asp-for="PromotionalPrice" class="form-control" type="number" min="0" step="any" placeholder="Để trống nếu không có" />
                            <span asp-validation-for="PromotionalPrice" class="text-danger small"></span>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Giá bán (đ)</label>
                            <input class="form-control" type="text" value="@Model.Price.ToString("N0") đ" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Giá khuyến mãi (đ)</label>
                            <input class="form-control" type="text" value="@(Model.PromotionalPrice.HasValue ? Model.PromotionalPrice.Value.ToString("N0") + " đ" : "Không có")" disabled />
                        </div>
                    }
                    <div class="col-md-4">
                        <label asp-for="Stock" class="form-label fw-semibold">Tồn kho</label>
                        <input asp-for="Stock" class="form-control" type="number" min="0" />
                        <span asp-validation-for="Stock" class="text-danger small"></span>
                    </div>

                    @if (canSetPrice)
                    {
                        <div class="col-md-6">
                            <label asp-for="PromotionalStartsAt" class="form-label fw-semibold">KM từ ngày</label>
                            <input asp-for="PromotionalStartsAt" id="promoStart" class="form-control" type="datetime-local" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PromotionalEndsAt" class="form-label fw-semibold">KM đến ngày</label>
                            <input asp-for="PromotionalEndsAt" id="promoEnd" class="form-control" type="datetime-local" />
                            <span id="promoDateError" class="text-danger small d-none">Ngày kết thúc phải sau ngày bắt đầu.</span>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">KM từ ngày</label>
                            <input class="form-control" type="text" value="@(Model.PromotionalStartsAt.HasValue ? Model.PromotionalStartsAt.Value.ToString("dd/MM/yyyy HH:mm") : "Không có")" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">KM đến ngày</label>
                            <input class="form-control" type="text" value="@(Model.PromotionalEndsAt.HasValue ? Model.PromotionalEndsAt.Value.ToString("dd/MM/yyyy HH:mm") : "Không có")" disabled />
                        </div>
                        <div class="col-12">
                            <div class="alert alert-warning py-2 mb-0">
                                <i class="bi bi-lock me-1"></i> Giá bán và thông tin khuyến mãi chỉ Manager mới có quyền chỉnh sửa.
                            </div>
                        </div>
                    }

                    <div class="col-12">
                        <label class="form-label fw-semibold">Ảnh bìa</label>
                        <label asp-for="ImageUrl" class="form-label small">Đường dẫn / URL ảnh</label>
                        <input asp-for="ImageUrl" class="form-control" id="imageUrlInput" placeholder="https://..." maxlength="255" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        <div id="imagePreview" class="mt-2 @(string.IsNullOrEmpty(Model.ImageUrl) ? "d-none" : "")">
                            <img id="previewImg" src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "" : Url.Content(Model.ImageUrl))" alt="Xem trước" class="rounded border"
                                 style="max-height:180px;object-fit:contain;" />
                        </div>
                    </div>

                    @* Tags *@
                    <div class="col-12">
                        <label class="form-label fw-semibold">Tags</label>
                        @if (ViewBag.AllTags != null && ((IEnumerable<dynamic>)ViewBag.AllTags).Any())
                        {
                            <div class="border rounded p-2 d-flex flex-wrap gap-2" style="max-height:140px;overflow-y:auto;">
                                @foreach (var tag in (IEnumerable<dynamic>)ViewBag.AllTags)
                                {
                                    var isChecked = Model.TagIds.Contains((int)tag.TagId);
                                    <div class="form-check form-check-inline m-0">
                                        <input class="form-check-input" type="checkbox"
                                               name="TagIds" value="@tag.TagId" id="tag_@tag.TagId"
                                               @(isChecked ? "checked" : "") />
                                        <label class="form-check-label" for="tag_@tag.TagId">@tag.Name</label>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mb-0">Chưa có tag nào. Hãy tạo tag trước.</p>
                        }
                    </div>
                </div>

                <hr class="my-4" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="bi bi-floppy me-1"></i> Cập nhật
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                    <a asp-action="Details" asp-route-id="@Model.BookId" class="btn btn-outline-info ms-auto">
                        <i class="bi bi-eye me-1"></i> Xem chi tiết
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            var urlInput = document.getElementById('imageUrlInput');
            var preview = document.getElementById('imagePreview');
            var img = document.getElementById('previewImg');
            function resolveImgUrl(u) {
                if (!u) return '';
                if (u.startsWith('http://') || u.startsWith('https://')) return u;
                if (u.startsWith('~/')) return u.replace('~', '');
                return u;
            }
            function showUrlPreview() {
                var url = urlInput.value.trim();
                if (url) {
                    img.src = resolveImgUrl(url);
                    preview.classList.remove('d-none');
                } else {
                    preview.classList.add('d-none');
                }
            }
            urlInput.addEventListener('input', showUrlPreview);
        })();

        (function () {
            var start = document.getElementById('promoStart');
            var end = document.getElementById('promoEnd');
            var err = document.getElementById('promoDateError');
            if (!start || !end) return;

            function validate() {
                if (start.value && end.value && end.value <= start.value) {
                    err.classList.remove('d-none');
                    end.setCustomValidity('invalid');
                } else {
                    err.classList.add('d-none');
                    end.setCustomValidity('');
                }
            }
            start.addEventListener('change', validate);
            end.addEventListener('change', validate);
        })();
    </script>
}
