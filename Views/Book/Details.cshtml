@model BookStore.Dtos.Common.BookDto
@{
    var canManageBooks = User.IsInRole("Admin") || User.IsInRole("Staff") || User.IsInRole("Manager");
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
    ViewData["Title"] = Model.Title;

    var effectivePrice = Model.PromotionalPrice.HasValue
        && Model.PromotionalStartsAt <= DateTime.UtcNow
        && (!Model.PromotionalEndsAt.HasValue || Model.PromotionalEndsAt >= DateTime.UtcNow)
        ? Model.PromotionalPrice.Value : Model.Price;
    var listPrice = Model.PromotionalPrice.HasValue ? Model.Price : (decimal?)null;
    var coverUrl = ViewBag.CoverUrl as string ?? "/images/header-slider/home-v1/header-slide.jpg";
    var isbn = $"978-604-{Model.BookId:D6}";
    var maxQty = Math.Max(0, Model.Stock);
    var canAddToCart = Model.Stock > 0;
    var isLoggedIn = User.Identity?.IsAuthenticated == true;
    var loginReturnUrl = Url.Action("Details", "Book", new { id = Model.BookId }) ?? "";
}
<link href="~/css/bookshop.css" rel="stylesheet" asp-append-version="true" />

<section class="page-banner services-banner">
    <div class="container">
        <div class="banner-header">
            <h2>Chi tiết sách</h2>
            <span class="underline center"></span>
            <p class="lead">@(Model.CategoryName ?? "Sách") — @(Model.AuthorName ?? "")</p>
        </div>
        <div class="breadcrumb">
            <ul>
                <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li><a asp-action="Shop">Danh sách sách</a></li>
                <li>@Model.Title</li>
            </ul>
        </div>
    </div>
</section>

<div id="content" class="site-content book-detail-shop">
    <div id="primary" class="content-area">
        <main id="main" class="site-main">
            <div class="booksmedia-detail-main">
                <div class="container">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="booksmedia-detail-box">
                                <div class="single-book-box">
                                    <div class="post-thumbnail">
                                        <div class="book-list-icon yellow-icon"></div>
                                        <img alt="@Model.Title" src="@coverUrl" />
                                    </div>
                                    <div class="post-detail">
                                        <header class="entry-header">
                                            <h2 class="entry-title" style="text-transform:none">@Model.Title</h2>
                                            <ul>
                                                <li><strong>Tác giả:</strong> <a href="#">@(Model.AuthorName ?? "—")</a></li>
                                                <li><strong>ISBN:</strong> @isbn</li>
                                                <li class="book-detail-rating-li">
                                                    <strong>Đánh giá:</strong>
                                                    <span class="book-detail-rating__meta">
                                                        <span class="book-detail-rating__score">4,5 / 5</span>
                                                        <span class="book-detail-rating__count">(128 lượt đánh giá)</span>
                                                    </span>
                                                </li>
                                                <li><strong>Danh mục:</strong> @(Model.CategoryName ?? "—")</li>
                                                <li><strong>Tồn kho:</strong> @Model.Stock</li>
                                            </ul>
                                        </header>
                                        <div class="entry-content post-buttons book-detail-actions" style="margin-top:12px">
                                            @if (TempData["CartError"] is string cartErr && !string.IsNullOrEmpty(cartErr))
                                            {
                                                <div class="alert alert-danger" style="margin-bottom:10px;padding:10px 14px">@cartErr</div>
                                            }
                                            <div class="shop-price-row">
                                                <span class="shop-price">@effectivePrice.ToString("N0") đ</span>
                                                @if (listPrice.HasValue)
                                                {
                                                    <span class="shop-price-was">@listPrice.Value.ToString("N0") đ</span>
                                                }
                                            </div>
                                            @if (canAddToCart && isLoggedIn)
                                            {
                                                <form asp-controller="Cart" asp-action="Add" method="post" class="book-detail-cart-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="bookId" value="@Model.BookId" />
                                                    <div class="shop-quantity-wrap">
                                                        <label class="shop-qty-label" for="bookQty">Số lượng</label>
                                                        <div class="shop-qty-control">
                                                            <button type="button" class="shop-qty-btn" data-dir="-1" aria-label="Giảm số lượng">−</button>
                                                            <input type="number"
                                                                   name="quantity"
                                                                   id="bookQty"
                                                                   class="shop-qty-input"
                                                                   value="1"
                                                                   min="1"
                                                                   max="@maxQty"
                                                                   step="1" />
                                                            <button type="button" class="shop-qty-btn" data-dir="1" aria-label="Tăng số lượng">+</button>
                                                        </div>
                                                    </div>
                                                    <div class="book-detail-cart-actions-row">
                                                        <button type="submit" class="btn btn-primary" style="background:#ff7236;border-color:#ff7236;margin-right:8px"><i class="fa fa-shopping-cart"></i> Thêm vào giỏ</button>
                                                        <a asp-action="Shop" class="btn btn-dark-gray">Tiếp tục mua sắm</a>
                                                    </div>
                                                </form>
                                            }
                                            else if (canAddToCart)
                                            {
                                                <div class="shop-quantity-wrap">
                                                    <label class="shop-qty-label" for="bookQty">Số lượng</label>
                                                    <div class="shop-qty-control">
                                                        <button type="button" class="shop-qty-btn" data-dir="-1" aria-label="Giảm số lượng">−</button>
                                                        <input type="number"
                                                               id="bookQty"
                                                               class="shop-qty-input"
                                                               value="1"
                                                               min="1"
                                                               max="@maxQty"
                                                               step="1" />
                                                        <button type="button" class="shop-qty-btn" data-dir="1" aria-label="Tăng số lượng">+</button>
                                                    </div>
                                                    <p class="shop-qty-hint text-muted small mb-0" style="margin-top:6px">Đăng nhập để thêm sách vào giỏ hàng.</p>
                                                </div>
                                                <div class="book-detail-cart-actions-row">
                                                    <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@loginReturnUrl" class="btn btn-primary" style="background:#ff7236;border-color:#ff7236;margin-right:8px"><i class="fa fa-shopping-cart"></i> Đăng nhập để mua</a>
                                                    <a asp-action="Shop" class="btn btn-dark-gray">Tiếp tục mua sắm</a>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="shop-quantity-wrap">
                                                    <label class="shop-qty-label" for="bookQty">Số lượng</label>
                                                    <div class="shop-qty-control">
                                                        <button type="button" class="shop-qty-btn" data-dir="-1" aria-label="Giảm số lượng" disabled>−</button>
                                                        <input type="number"
                                                               id="bookQty"
                                                               class="shop-qty-input"
                                                               value="0"
                                                               min="0"
                                                               max="@maxQty"
                                                               step="1"
                                                               disabled="disabled" />
                                                        <button type="button" class="shop-qty-btn" data-dir="1" aria-label="Tăng số lượng" disabled>+</button>
                                                    </div>
                                                    <p class="shop-qty-hint text-muted small mb-0">Hết hàng — không thể đặt thêm.</p>
                                                </div>
                                                <div class="book-detail-cart-actions-row">
                                                    <span class="btn btn-primary book-detail-cart-disabled" style="background:#ccc;border-color:#ccc;margin-right:8px;cursor:not-allowed"><i class="fa fa-shopping-cart"></i> Hết hàng</span>
                                                    <a asp-action="Shop" class="btn btn-dark-gray">Tiếp tục mua sắm</a>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(Model.Description))
                                {
                                    <p style="margin-top:20px;line-height:1.7"><strong>Mô tả:</strong> @Model.Description</p>
                                }

                                <div class="table-tabs" id="responsiveTabs" style="margin-top:28px">
                                    <ul class="nav nav-tabs">
                                        <li class="active"><b class="arrow-up"></b><a data-toggle="tab" href="#tab-reviews">Đánh giá &amp; bình luận</a></li>
                                        <li><b class="arrow-up"></b><a data-toggle="tab" href="#tab-spec">Thông tin thêm</a></li>
                                    </ul>
                                    <div class="tab-content" style="padding-top:16px">
                                        <div id="tab-reviews" class="tab-pane fade in active">
                                            <p class="text-muted" style="font-size:13px;margin-bottom:16px">Phần dưới là <strong>nội dung tĩnh minh họa</strong> (chưa gắn cơ sở dữ liệu).</p>
                                            <div class="comment-box">
                                                <div class="meta">Minh Anh · ★★★★★ · 12/03/2026</div>
                                                <p>Sách in đẹp, giao hàng nhanh. Nội dung đúng như mô tả, rất đáng đọc lại nhiều lần.</p>
                                            </div>
                                            <div class="comment-box">
                                                <div class="meta">Hải Đăng · ★★★★☆ · 02/03/2026</div>
                                                <p>Bản dịch ổn, có vài chỗ có thể chỉnh sửa cho mượt hơn nhưng nhìn chung hài lòng.</p>
                                            </div>
                                            <div class="comment-box">
                                                <div class="meta">Thu Trang · ★★★★★ · 20/02/2026</div>
                                                <p>Đóng gói cẩn thận, tặng kèm bookmark xinh. Sẽ ủng hộ shop tiếp.</p>
                                            </div>
                                        </div>
                                        <div id="tab-spec" class="tab-pane fade">
                                            <ul class="detail-page-listing">
                                                <li><strong>Mã sách:</strong> #@Model.BookId</li>
                                                <li><strong>ISBN (tham khảo):</strong> @isbn</li>
                                                <li><strong>Danh mục:</strong> @(Model.CategoryName ?? "—")</li>
                                                @if (Model.CreatedAt.HasValue)
                                                {
                                                    <li><strong>Cập nhật gần nhất:</strong> @Model.CreatedAt.Value.ToLocalTime().ToString("dd/MM/yyyy")</li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </div>

                                @if (canManageBooks)
                                {
                                    <div class="well" style="margin-top:24px;background:#fafafa;border-radius:6px">
                                        <strong>Quản trị:</strong>
                                        <a asp-action="Edit" asp-route-id="@Model.BookId" class="btn btn-warning btn-sm">Sửa sách</a>
                                        <form asp-action="ChangeStatus" asp-route-id="@Model.BookId" method="post" style="display:inline-block;margin-left:6px"
                                              onsubmit="return confirm('@(Model.IsActive ? "Vô hiệu hóa sách này?" : "Kích hoạt sách này?")')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-default btn-sm">@(Model.IsActive ? "Vô hiệu hóa" : "Kích hoạt")</button>
                                        </form>
                                        <a asp-action="Index" class="btn btn-link btn-sm">Quản lý sách</a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var input = document.getElementById('bookQty');
            if (!input || input.disabled) return;

            var min = parseInt(input.getAttribute('min'), 10);
            if (isNaN(min)) min = 0;
            var max = parseInt(input.getAttribute('max'), 10);
            if (isNaN(max)) max = 9999;

            function clamp() {
                var v = parseInt(input.value, 10);
                if (isNaN(v)) v = min;
                if (v < min) v = min;
                if (v > max) v = max;
                input.value = v;
            }

            document.querySelectorAll('.book-detail-actions .shop-qty-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    if (btn.disabled || input.disabled) return;
                    var d = parseInt(btn.getAttribute('data-dir'), 10);
                    var v = parseInt(input.value, 10);
                    if (isNaN(v)) v = min;
                    v += d;
                    if (v < min) v = min;
                    if (v > max) v = max;
                    input.value = v;
                });
            });

            input.addEventListener('change', clamp);
            input.addEventListener('blur', clamp);
        })();
    </script>
}
