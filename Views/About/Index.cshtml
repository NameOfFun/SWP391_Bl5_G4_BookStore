@model IReadOnlyList<BookStore.Dtos.Common.AboutDto>
@using BookStore.Helpers
@{
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
    ViewData["Title"] = "Tin tức & Giới thiệu";
    ViewData["LibrariaInnerHeader"] = true;
    var recent = Model.Take(5).ToList();
}

<section class="page-banner news-listing-banner services-banner">
    <div class="container">
        <div class="banner-header">
            <h2>Tin tức &amp; Giới thiệu</h2>
            <span class="underline center"></span>
            <p class="lead">Cập nhật từ BookStore — dành cho độc giả và khách hàng.</p>
        </div>
        <div class="breadcrumb">
            <ul>
                <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li>Tin tức</li>
            </ul>
        </div>
    </div>
</section>

<div id="content" class="site-content">
    <div id="primary" class="content-area">
        <main id="main" class="site-main">
            <div class="main-news-list">
                <div class="container">
                    <div class="row">
                        <div class="col-md-9 col-md-push-3 news-events-list-view">
                            @if (!Model.Any())
                            {
                                <div class="news-list-box">
                                    <p class="text-center text-muted" style="padding:48px 16px">Chưa có bài viết nào. Vui lòng quay lại sau.</p>
                                </div>
                            }
                            else
                            {
                                @foreach (var item in Model)
                                {
                                    var img = AboutDisplayHelper.ListingImage(item.AboutId);
                                    var summary = AboutDisplayHelper.PlainTextSummary(item.ContentHtml);
                                    var dateStr = item.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy");
                                    <div class="news-list-box">
                                        <div class="single-news-list">
                                            <figure>
                                                <a asp-action="Article" asp-route-id="@item.AboutId">
                                                    <img src="@img" alt="@item.Title" />
                                                </a>
                                            </figure>
                                            <div class="content-block">
                                                <div class="member-info">
                                                    <div class="content_meta_category">
                                                        <span class="arrow-right"></span>
                                                        <span>BookStore</span>
                                                    </div>
                                                    <ul class="news-event-info">
                                                        <li>
                                                            <a href="#" onclick="return false;">
                                                                <i class="fa fa-calendar"></i>
                                                                @dateStr
                                                            </a>
                                                        </li>
                                                    </ul>
                                                    <h3><a asp-action="Article" asp-route-id="@item.AboutId">@item.Title</a></h3>
                                                    @if (!string.IsNullOrEmpty(summary))
                                                    {
                                                        <p>@summary</p>
                                                    }
                                                    <a class="btn btn-primary" asp-action="Article" asp-route-id="@item.AboutId">Đọc thêm</a>
                                                </div>
                                            </div>
                                            <div class="clearfix"></div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                        <div class="col-md-3 col-md-pull-9">
                            <aside id="secondary" class="sidebar widget-area">
                                <div class="widget widget_recent_entries">
                                    <h4 class="widget-title" data-control>Bài gần đây</h4>
                                    <ul>
                                        @if (!recent.Any())
                                        {
                                            <li><p class="text-muted small">Chưa có bài viết.</p></li>
                                        }
                                        else
                                        {
                                            foreach (var item in recent)
                                            {
                                                var thumb = AboutDisplayHelper.ListingImage(item.AboutId);
                                                <li>
                                                    <figure>
                                                        <img src="@thumb" alt="@item.Title" />
                                                    </figure>
                                                    <a asp-action="Article" asp-route-id="@item.AboutId">@item.Title</a>
                                                    <span><i class="fa fa-calendar"></i> &nbsp; @item.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                                                    <div class="clearfix"></div>
                                                </li>
                                            }
                                        }
                                    </ul>
                                </div>
                                <div class="widget widget_text">
                                    <h4 class="widget-title" data-control>Liên hệ</h4>
                                    <div class="textwidget">
                                        <p class="small">Email: <a href="mailto:support@bookstore.com">support@bookstore.com</a></p>
                                        <p class="small">Điện thoại: <a href="tel:+61283766284">+61-3-8376-6284</a></p>
                                    </div>
                                </div>
                            </aside>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
