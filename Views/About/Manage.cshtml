@model IReadOnlyList<BookStore.Dtos.Common.AboutDto>
@{
    ViewData["Title"] = "Quản lý Giới thiệu / Tin tức";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Quản lý nội dung Giới thiệu &amp; Tin tức</h2>
        <div class="d-flex gap-2">
            <a asp-action="Index" asp-controller="About" target="_blank" class="btn btn-outline-secondary btn-sm">Xem trang công khai</a>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Thêm mới
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Tiêu đề</th>
                <th>Cập nhật lần cuối</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AboutId</td>
                    <td>@item.Title</td>
                    <td>@item.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Article" asp-route-id="@item.AboutId" target="_blank" class="btn btn-sm btn-outline-primary">Xem</a>
                        <a asp-action="Edit" asp-route-id="@item.AboutId" class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.AboutId" class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">Chưa có dữ liệu</td>
                </tr>
            }
        </tbody>
    </table>
</div>
