@model BookStore.Dtos.Auth.ChangePasswordDto
@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<!-- Start: Page Banner -->
<section class="page-banner services-banner">
    <div class="container">
        <div class="banner-header">
            <h2>Đổi mật khẩu</h2>
            <span class="underline center"></span>
            <p class="lead">Thay đổi mật khẩu để bảo vệ tài khoản</p>
        </div>
        <div class="breadcrumb">
            <ul>
                <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li><a asp-controller="Account" asp-action="Profile">Tài khoản</a></li>
                <li>Đổi mật khẩu</li>
            </ul>
        </div>
    </div>
</section>
<!-- End: Page Banner -->

<!-- Start: Change Password Section -->
<div class="signin-main">
    <div class="container">
        <div class="woocommerce">
            <!-- Success/Error Messages -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="woocommerce-message">
                    <i class="fa fa-check"></i> @TempData["SuccessMessage"]
                </div>
            }
            
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="woocommerce-error">
                    <i class="fa fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                </div>
            }

            <div class="woocommerce-login">
                <div class="company-info signin-register">
                    <!-- Change Password Form -->
                    <div class="col-md-6 col-md-offset-3 border-dark-left">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="company-detail bg-dark margin-left">
                                    <div class="signin-head">
                                        <h2><i class="fa fa-lock"></i> Thay đổi mật khẩu</h2>
                                        <span class="underline left"></span>
                                    </div>
                                    
                                    <form class="login" asp-action="ChangePassword" method="post">
                                        @Html.AntiForgeryToken()
                                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                        
                                        <p class="form-row form-row-wide input-required">
                                            <label for="CurrentPassword"><i class="fa fa-key"></i> Mật khẩu hiện tại:</label>
                                            <input type="password" asp-for="CurrentPassword" id="currentPassword" class="input-text" placeholder="Nhập mật khẩu hiện tại" required />
                                            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                                        </p>
                                        
                                        <div class="clear"></div>
                                        
                                        <p class="form-row form-row-first input-required">
                                            <label for="NewPassword"><i class="fa fa-lock"></i> Mật khẩu mới:</label>
                                            <input type="password" asp-for="NewPassword" id="newPassword" class="input-text" placeholder="Mật khẩu mới" required />
                                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                                        </p>
                                        
                                        <p class="form-row form-row-last input-required">
                                            <label for="ConfirmPassword"><i class="fa fa-lock"></i> Xác nhận mật khẩu:</label>
                                            <input type="password" asp-for="ConfirmPassword" id="confirmPassword" class="input-text" placeholder="Nhập lại mật khẩu mới" required />
                                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                        </p>
                                        
                                        <div class="clear"></div>
                                        
                                        <!-- Password Requirements -->
                                        <div class="password-requirements">
                                            <p><i class="fa fa-info-circle"></i> Mật khẩu phải:</p>
                                            <ul>
                                                <li><i class="fa fa-check"></i> Có ít nhất 6 ký tự</li>
                                                <li><i class="fa fa-check"></i> Có ít nhất 1 chữ số</li>
                                                <li><i class="fa fa-check"></i> Có ít nhất 1 chữ thường</li>
                                            </ul>
                                        </div>
                                        
                                        <div class="form-actions text-center">
                                            <input type="submit" value="Đổi mật khẩu" class="button btn btn-default">
                                            <a asp-action="Profile" class="button btn btn-default">
                                                <i class="fa fa-arrow-left"></i> Quay lại
                                            </a>
                                        </div>
                                    </form>
                                </div>
                                
                                <div class="company-detail new-account bg-light margin-left mt-20">
                                    <p class="text-center">
                                        <a asp-action="EditProfile">
                                            <i class="fa fa-edit"></i> Cập nhật thông tin khác
                                        </a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- End: Change Password Section -->

<style>
    .password-requirements {
        background: #2a2a2a;
        padding: 15px;
        margin: 15px 0;
        border-radius: 4px;
    }
    .password-requirements p {
        color: #a8a8a8;
        margin-bottom: 10px;
        font-weight: bold;
    }
    .password-requirements ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .password-requirements li {
        color: #7fba00;
        padding: 3px 0;
        font-size: 13px;
    }
    .password-requirements li i {
        margin-right: 8px;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Real-time password match validation
        document.getElementById('confirmPassword').addEventListener('input', function() {
            var newPass = document.getElementById('newPassword').value;
            var confirmPass = this.value;
            
            if (newPass !== confirmPass && confirmPass.length > 0) {
                this.style.borderColor = '#a94442';
            } else {
                this.style.borderColor = '#3a3a3a';
            }
        });
    </script>
}
