@model BookStore.Dtos.Auth.ResetPasswordDto
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<section class="page-banner services-banner">
    <div class="container">
        <div class="banner-header">
            <h2>Đặt lại mật khẩu</h2>
            <span class="underline center"></span>
            <p class="lead">Tạo mật khẩu mới cho tài khoản của bạn</p>
        </div>
        <div class="breadcrumb">
            <ul>
                <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li>Đặt lại mật khẩu</li>
            </ul>
        </div>
    </div>
</section>

<div class="signin-main">
    <div class="container">
        <div class="woocommerce">
            <div class="woocommerce-login">
                <div class="company-info signin-register">
                    <div class="col-md-6 col-md-offset-3">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="company-detail bg-dark">
                                    <div class="signin-head">
                                        <h2>Tạo mật khẩu mới</h2>
                                        <span class="underline left"></span>
                                    </div>

                                    <form asp-action="ResetPassword" method="post" class="login">
                                        @Html.AntiForgeryToken()
                                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                                        <p class="form-row form-row-wide">
                                            <label for="Email">Email</label>
                                            <input type="email" asp-for="Email" class="input-text" readonly />
                                        </p>

                                        <input type="hidden" asp-for="Token" />

                                        <p class="form-row form-row-wide input-required">
                                            <label for="NewPassword">Mật khẩu mới</label>
                                            <input type="password" asp-for="NewPassword" class="input-text"
                                                   placeholder="Nhập mật khẩu mới" required />
                                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                                        </p>

                                        <p class="form-row form-row-wide input-required">
                                            <label for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                                            <input type="password" asp-for="ConfirmPassword" class="input-text"
                                                   placeholder="Nhập lại mật khẩu mới" required />
                                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                        </p>

                                        <p class="form-row">
                                            <input type="submit" value="Đặt lại mật khẩu"
                                                   class="button btn btn-default" />
                                        </p>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}