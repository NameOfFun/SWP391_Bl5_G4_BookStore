@model BookStore.Dtos.Auth.ForgotPasswordDto
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<section class="page-banner services-banner">
    <div class="container">
        <div class="banner-header">
            <h2>Quên mật khẩu</h2>
            <span class="underline center"></span>
            <p class="lead">Nhập email của bạn để nhận liên kết đặt lại mật khẩu</p>
        </div>
        <div class="breadcrumb">
            <ul>
                <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li>Quên mật khẩu</li>
            </ul>
        </div>
    </div>
</section>

<div class="signin-main">
    <div class="container">
        <div class="woocommerce">
            <div class="woocommerce-login">
                <div class="company-info signin-register">
                    <div class="col-md-6 col-md-offset-3">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="company-detail bg-dark">
                                    <div class="signin-head">
                                        <h2>Khôi phục mật khẩu</h2>
                                        <span class="underline left"></span>
                                    </div>

                                    <div class="alert alert-info">
                                        <i class="fa fa-info-circle"></i> 
                                        Nhập địa chỉ email đã đăng ký. Chúng tôi sẽ gửi cho bạn một liên kết để đặt lại mật khẩu.
                                    </div>

                                    <form asp-action="ForgotPassword" method="post" class="login">
                                        @Html.AntiForgeryToken()
                                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                                        <p class="form-row form-row-wide input-required">
                                            <label for="Email">Email</label>
                                            <input type="email" asp-for="Email" class="input-text" 
                                                   placeholder="Nhập email của bạn" required />
                                            <span asp-validation-for="Email" class="text-danger"></span>
                                        </p>

                                        <p class="form-row">
                                            <input type="submit" value="Gửi yêu cầu" 
                                                   class="button btn btn-default" />
                                            <a asp-action="Login" class="btn btn-link"> Quay lại đăng nhập</a>
                                        </p>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}