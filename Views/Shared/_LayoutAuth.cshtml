<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    
    <!-- Favicon -->
    <link href="~/images/favicon.ico" rel="icon" type="image/x-icon" />
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i,800,800i|Lato:100,100i,300,300i,400,400i,700,700i,900,900i" rel="stylesheet" />
    
    <!-- Bootstrap 3 (for template compatibility) -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" integrity="sha384-BVYiiSIFeK1dGmJRAkycuHAHRg32OmUcww7on3RYdg4Va+PmSTsz/K68vbdEjh4u" crossorigin="anonymous">
    
    <!-- Font Awesome -->
    <link href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet" />
    
    <!-- Template Styles -->
    <link href="~/style.css" rel="stylesheet" type="text/css" />
</head>

<body>
    <!-- Start: Header Section -->
    <header id="header-v1" class="navbar-wrapper inner-navbar-wrapper">
        <div class="container">
            <div class="row">
                <nav class="navbar navbar-default">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="navbar-header">
                                <div class="navbar-brand">
                                    <h1>
                                        <a asp-controller="Home" asp-action="Index">
                                            <img src="~/images/libraria-logo-v1.png" alt="BookStore" />
                                        </a>
                                    </h1>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-9">
                            <!-- Header Topbar -->
                            <div class="header-topbar hidden-sm hidden-xs">
                                <div class="row">
                                    <div class="col-sm-6">
                                        <div class="topbar-info">
                                            <a href="tel:+61-3-8376-6284"><i class="fa fa-phone"></i>+61-3-8376-6284</a>
                                            <span>/</span>
                                            <a href="mailto:support@bookstore.com"><i class="fa fa-envelope"></i>support@bookstore.com</a>
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="topbar-links">
                                            @if (User.Identity?.IsAuthenticated == true)
                                            {
                                                <a asp-controller="Account" asp-action="Profile">
                                                    <i class="fa fa-user"></i>@User.Identity.Name
                                                </a>
                                                <span>|</span>
                                                <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" style="display:inline;">
                                                    <button type="submit" style="background:none;border:none;color:inherit;cursor:pointer;padding:0;">
                                                        <i class="fa fa-lock"></i> Đăng xuất
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <a asp-controller="Account" asp-action="Login">
                                                    <i class="fa fa-lock"></i> Đăng nhập
                                                </a>
                                                <span>|</span>
                                                <a asp-controller="Account" asp-action="Register">
                                                    <i class="fa fa-user-plus"></i> Đăng ký
                                                </a>
                                            }
                                            <span>|</span>
                                            <div class="header-cart dropdown">
                                                <a data-toggle="dropdown" class="dropdown-toggle" href="#">
                                                    <i class="fa fa-shopping-cart"></i>
                                                    <small id="cartCount">0</small>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="navbar-collapse hidden-sm hidden-xs">
                                <ul class="nav navbar-nav">
                                    <li class="dropdown active">
                                        <a data-toggle="dropdown" class="dropdown-toggle disabled" asp-controller="Home" asp-action="Index">Trang chủ</a>
                                    </li>
                                    <li class="dropdown">
                                        <a data-toggle="dropdown" class="dropdown-toggle disabled" asp-controller="Book" asp-action="Index">Sách</a>
                                        <ul class="dropdown-menu">
                                            <li><a asp-controller="Book" asp-action="List">Danh sách sách</a></li>
                                            <li><a asp-controller="Book" asp-action="Grid">Lưới sách</a></li>
                                        </ul>
                                    </li>
                                    <li class="dropdown">
                                        <a data-toggle="dropdown" class="dropdown-toggle disabled" href="#">Tin tức</a>
                                        <ul class="dropdown-menu">
                                            <li><a href="#">Tin tức</a></li>
                                            <li><a href="#">Chi tiết tin tức</a></li>
                                        </ul>
                                    </li>
                                    <li class="dropdown">
                                        <a data-toggle="dropdown" class="dropdown-toggle disabled" href="#">Giỏ hàng</a>
                                        <ul class="dropdown-menu">
                                            <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                                            <li><a asp-controller="Checkout" asp-action="Index">Thanh toán</a></li>
                                            <li><a asp-controller="Order" asp-action="MyOrders">Đơn hàng của tôi</a></li>
                                        </ul>
                                    </li>
                                    <li><a href="#">Liên hệ</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <!-- Mobile Menu -->
                    <div class="mobile-menu hidden-lg hidden-md">
                        <a href="#mobile-menu"><i class="fa fa-navicon"></i></a>
                        <div id="mobile-menu">
                            <ul>
                                <li class="mobile-title">
                                    <h4>Navigation</h4>
                                    <a href="#" class="close"></a>
                                </li>
                                <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                                <li><a asp-controller="Book" asp-action="Index">Sách</a></li>
                                <li><a href="#">Tin tức</a></li>
                                <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                                <li><a href="#">Liên hệ</a></li>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <li><a asp-controller="Account" asp-action="Profile">Tài khoản</a></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" style="background:none;border:none;padding:0;">Đăng xuất</button>
                                        </form>
                                    </li>
                                }
                                else
                                {
                                    <li><a asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                                    <li><a asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                                }
                            </ul>
                        </div>
                    </div>
                </nav>
            </div>
        </div>
    </header>
    <!-- End: Header Section -->

    @RenderBody()

    <!-- Start: Social Network -->
    <section class="social-network section-padding">
        <div class="container">
            <div class="center-content">
                <h2 class="section-title">Follow Us</h2>
                <span class="underline center"></span>
                <p class="lead">Kết nối với chúng tôi trên các mạng xã hội</p>
            </div>
            <ul>
                <li>
                    <a class="facebook" href="#" target="_blank">
                        <span><i class="fa fa-facebook-f"></i></span>
                    </a>
                </li>
                <li>
                    <a class="twitter" href="#" target="_blank">
                        <span><i class="fa fa-twitter"></i></span>
                    </a>
                </li>
                <li>
                    <a class="google" href="#" target="_blank">
                        <span><i class="fa fa-google-plus"></i></span>
                    </a>
                </li>
                <li>
                    <a class="rss" href="#" target="_blank">
                        <span><i class="fa fa-rss"></i></span>
                    </a>
                </li>
                <li>
                    <a class="linkedin" href="#" target="_blank">
                        <span><i class="fa fa-linkedin"></i></span>
                    </a>
                </li>
                <li>
                    <a class="youtube" href="#" target="_blank">
                        <span><i class="fa fa-youtube"></i></span>
                    </a>
                </li>
            </ul>
        </div>
    </section>
    <!-- End: Social Network -->

    <!-- Start: Footer -->
    <footer class="site-footer">
        <div class="container">
            <div id="footer-widgets">
                <div class="row">
                    <div class="col-md-4 col-sm-6 widget-container">
                        <div id="text-2" class="widget widget_text">
                            <h3 class="footer-widget-title">Về BookStore</h3>
                            <span class="underline left"></span>
                            <div class="textwidget">
                                Chúng tôi cung cấp những cuốn sách chất lượng nhất với giá cả hợp lý.
                            </div>
                            <address>
                                <div class="info">
                                    <i class="fa fa-location-arrow"></i>
                                    <span>123 Đường ABC, Quận 1, TP.HCM</span>
                                </div>
                                <div class="info">
                                    <i class="fa fa-envelope"></i>
                                    <span><a href="mailto:support@bookstore.com">support@bookstore.com</a></span>
                                </div>
                                <div class="info">
                                    <i class="fa fa-phone"></i>
                                    <span><a href="tel:012-345-6789">+012-345-6789</a></span>
                                </div>
                            </address>
                        </div>
                    </div>
                    <div class="col-md-2 col-sm-6 widget-container">
                        <div id="nav_menu-2" class="widget widget_nav_menu">
                            <h3 class="footer-widget-title">Liên kết nhanh</h3>
                            <span class="underline left"></span>
                            <div class="menu-quick-links-container">
                                <ul id="menu-quick-links" class="menu">
                                    <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                                    <li><a asp-controller="Book" asp-action="Index">Sách</a></li>
                                    <li><a href="#">Tin tức</a></li>
                                    <li><a href="#">Liên hệ</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="clearfix hidden-lg hidden-md hidden-xs tablet-margin-bottom"></div>
                    <div class="col-md-2 col-sm-6 widget-container">
                        <div id="text-4" class="widget widget_text">
                            <h3 class="footer-widget-title">Giờ mở cửa</h3>
                            <span class="underline left"></span>
                            <div class="timming-text-widget">
                                <time>Mon - Thu: 9 am - 9 pm</time>
                                <time>Fri: 9 am - 6 pm</time>
                                <time>Sat: 9 am - 5 pm</time>
                                <time>Sun: 1 pm - 6 pm</time>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 col-sm-6 widget-container">
                        <div class="widget twitter-widget">
                            <h3 class="footer-widget-title">Tin mới nhất</h3>
                            <span class="underline left"></span>
                            <div id="twitter-feed">
                                <ul>
                                    <li>
                                        <p>Cập nhật những cuốn sách mới nhất tại BookStore!</p>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="sub-footer">
            <div class="container">
                <div class="row">
                    <div class="footer-text col-md-3">
                        <p>&copy; 2026 BookStore. All rights reserved.</p>
                    </div>
                    <div class="col-md-9 pull-right">
                        <ul>
                            <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                            <li><a asp-controller="Book" asp-action="Index">Sách</a></li>
                            <li><a href="#">Tin tức</a></li>
                            <li><a href="#">Liên hệ</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <!-- End: Footer -->

    <!-- Scripts -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.12.4/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js" integrity="sha384-Tc5IQib027qvyjSMfHjOMaLkfuWVxZxUPnCJA7l2mCWNIpG9mGCD8wGNIcPD7Txa" crossorigin="anonymous"></script>
    <script src="~/js/main.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>