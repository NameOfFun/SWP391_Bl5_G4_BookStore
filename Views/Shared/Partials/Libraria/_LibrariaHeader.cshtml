@using System.Security.Claims
@inject BookStore.Service.Interfaces.ICartService CartService
@{
    var useInnerHeader = ViewData["LibrariaInnerHeader"] as bool? ?? true;
    var headerClass = useInnerHeader ? "navbar-wrapper inner-navbar-wrapper" : "navbar-wrapper";
    var headerCartQty = 0;
    if (User.Identity?.IsAuthenticated == true && User is ClaimsPrincipal cp)
    {
        var uid = cp.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrEmpty(uid))
            headerCartQty = await CartService.GetTotalItemQuantityAsync(uid);
    }
    var headerCartBadge = headerCartQty > 99 ? "99+" : headerCartQty.ToString();
}
<!-- Start: Header Section -->
<header id="header-v1" class="@headerClass">
    <div class="container">
        <div class="row">
            <nav class="navbar navbar-default">
                <div class="row">
                    <div class="col-md-3">
                        <div class="navbar-header">
                            <div class="navbar-brand">
                                <h1>
                                    <a asp-controller="Home" asp-action="Index" class="navbar-brand-home-link">
                                        <img src="~/images/libraria-logo-v1.png" alt="BookStore" asp-append-version="true" />
                                    </a>
                                </h1>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-9">
                        <!-- Header Topbar -->
                        <div class="header-topbar hidden-sm hidden-xs">
                            <div class="row">
                                <div class="col-sm-6">
                                    <div class="topbar-info">
                                        <a href="tel:+84978775882"><i class="fa fa-phone"></i>+84978775882</a>
                                        <span>/</span>
                                        <a href="mailto:support@bookstore.com"><i class="fa fa-envelope"></i>support@bookstore.com</a>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="topbar-links">
                                        @if (User.Identity?.IsAuthenticated == true)
                                        {
                                            <a asp-controller="Account" asp-action="Profile">
                                                <i class="fa fa-user"></i>@User.Identity.Name
                                            </a>
                                            <span>|</span>
                                            <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" style="display:inline;">
                                                <button type="submit" style="background:none;border:none;color:inherit;cursor:pointer;padding:0;">
                                                    <i class="fa fa-lock"></i> Đăng xuất
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <a asp-controller="Account" asp-action="Login">
                                                <i class="fa fa-lock"></i> Đăng nhập
                                            </a>
                                            <span>|</span>
                                            <a asp-controller="Account" asp-action="Register">
                                                <i class="fa fa-user-plus"></i> Đăng ký
                                            </a>
                                        }
                                        <span>|</span>
                                        <div class="header-cart">
                                            <a asp-controller="Cart" asp-action="Index" class="header-cart-link" title="Giỏ hàng">
                                                <i class="fa fa-shopping-cart" aria-hidden="true"></i>
                                                @if (headerCartQty > 0)
                                                {
                                                    <small id="cartCount" class="header-cart-badge" aria-label="@headerCartQty sản phẩm trong giỏ">@headerCartBadge</small>
                                                }
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="navbar-collapse hidden-sm hidden-xs">
                            <ul class="nav navbar-nav">
                                <li class="dropdown active">
                                    <a data-toggle="dropdown" class="dropdown-toggle disabled" asp-controller="Home" asp-action="Index">Trang chủ</a>
                                </li>
                                <li class="dropdown">
                                    <a data-toggle="dropdown" class="dropdown-toggle disabled" asp-controller="Book" asp-action="Shop">Sách</a>
                                    <ul class="dropdown-menu">
                                        <li><a asp-controller="Book" asp-action="Categories">Theo danh mục (bảng)</a></li>
                                        <li><a asp-controller="Book" asp-action="Shop">Danh sách sách</a></li>
                                        @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Staff"))
                                        {
                                            <li><a asp-controller="Book" asp-action="Index">CMS</a></li>
                                        }
                                    </ul>
                                </li>
                                <li class="dropdown">
                                    <a data-toggle="dropdown" class="dropdown-toggle disabled" asp-controller="About" asp-action="Index">Tin tức</a>
                                    <ul class="dropdown-menu">
                                        <li><a asp-controller="About" asp-action="Index">Tất cả tin &amp; giới thiệu</a></li>
                                    </ul>
                                </li>
                                <li class="dropdown">
                                    <a data-toggle="dropdown" class="dropdown-toggle disabled" href="#">Giỏ hàng</a>
                                    <ul class="dropdown-menu">
                                        <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                                        <li><a asp-controller="Checkout" asp-action="Index">Thanh toán</a></li>
                                        <li><a asp-controller="Order" asp-action="MyOrders">Đơn hàng của tôi</a></li>
                                    </ul>
                                </li>
                                <li><a asp-controller="About" asp-action="Index">Liên hệ</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
                <!-- Mobile Menu -->
                <div class="mobile-menu hidden-lg hidden-md">
                    <a href="#mobile-menu"><i class="fa fa-navicon"></i></a>
                    <div id="mobile-menu">
                        <ul>
                            <li class="mobile-title">
                                <h4>Điều hướng</h4>
                                <a href="#" class="close" aria-label="Đóng menu"></a>
                            </li>
                            <li><a asp-controller="Home" asp-action="Index"><i class="fa fa-home" aria-hidden="true"></i><span>Trang chủ</span></a></li>
                            <li><a asp-controller="Book" asp-action="Shop"><i class="fa fa-book" aria-hidden="true"></i><span>Sách</span></a></li>
                            <li><a asp-controller="About" asp-action="Index"><i class="fa fa-newspaper-o" aria-hidden="true"></i><span>Tin tức</span></a></li>
                            <li>
                                <a asp-controller="Cart" asp-action="Index">
                                    <i class="fa fa-shopping-cart" aria-hidden="true"></i>
                                    <span>Giỏ hàng</span>
                                    @if (headerCartQty > 0)
                                    {
                                        <span class="mobile-cart-badge">@headerCartBadge</span>
                                    }
                                </a>
                            </li>
                            <li><a asp-controller="About" asp-action="Index"><i class="fa fa-envelope-o" aria-hidden="true"></i><span>Liên hệ</span></a></li>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li><a asp-controller="Account" asp-action="Profile"><i class="fa fa-user" aria-hidden="true"></i><span>Tài khoản</span></a></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="mobile-nav-logout-form">
                                        <button type="submit" class="mobile-nav-logout-btn">
                                            <i class="fa fa-sign-out" aria-hidden="true"></i><span>Đăng xuất</span>
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li><a asp-controller="Account" asp-action="Login"><i class="fa fa-lock" aria-hidden="true"></i><span>Đăng nhập</span></a></li>
                                <li><a asp-controller="Account" asp-action="Register"><i class="fa fa-user-plus" aria-hidden="true"></i><span>Đăng ký</span></a></li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </div>
    </div>
</header>
<!-- End: Header Section -->
